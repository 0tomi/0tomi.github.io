---
// ============================================================
// Maqueta 09 — "Noir"
// Combinación pedida por el usuario:
//  · Hero centrado tipo Showcase (foto protagonista + nombre display).
//  · Proyectos como filas editoriales numeradas (01/02/03) con hairlines.
// Tema OSCURO: fondo casi negro, tinta clara, un único acento ladrillo.
// Sensación: revista impresa de noche.
// Todo el contenido sale de src/data/profile.ts (fuente única de verdad).
// Página autocontenida: estilos y scripts propios, sin CSS global.
// ============================================================
import { profile, projects, skills } from '../../data/profile';

const year = new Date().getFullYear();
const hasGithub = profile.links.github.length > 0;
const hasLinkedin = profile.links.linkedin.length > 0;

const sections = [
	{ n: '01', label: 'Proyectos' },
	{ n: '02', label: 'Stack' },
	{ n: '03', label: 'Contacto' },
];

const metaDescription = `Portfolio de ${profile.name}, ${profile.role}. ${profile.tagline}`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={metaDescription} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{profile.name} — {profile.role} · Noir</title>
	</head>
	<body>
		<div class="page">
			<!-- ===================== HERO (centrado) ===================== -->
			<header class="hero">
				<div class="hero__inner">
					<figure class="hero__portrait intro" style="--i: 0">
						<img
							class="hero__photo"
							src={profile.avatar}
							alt={`Retrato de ${profile.name}`}
							width="160"
							height="160"
							decoding="async"
							fetchpriority="high"
						/>
					</figure>
					<h1 class="hero__name intro" style="--i: 1">{profile.name}</h1>
					<p class="hero__role intro" style="--i: 2">{profile.role}</p>
					<p class="hero__tagline intro" style="--i: 3">{profile.tagline}</p>
				</div>
			</header>

			<main>
				<!-- ===================== 01 — PROYECTOS ===================== -->
				<section class="section" aria-labelledby="s-work">
					<div class="section__head reveal">
						<span class="mono section__num">{sections[0].n}</span>
						<h2 class="section__title" id="s-work">{sections[0].label}</h2>
						<span class="rule" aria-hidden="true"></span>
					</div>

					<ol class="work">
						{
							projects.map((project) => (
								<li class="work__item reveal">
									<div class="work__row">
										<figure class="work__media">
											{project.image ? (
												<button
													type="button"
													class="work__zoom"
													data-zoom
													data-src={project.image}
													data-caption={project.name}
													aria-label={`Ampliar captura de ${project.name}`}
												>
													<img
														class="work__shot"
														src={project.image}
														alt={`Captura de ${project.name}`}
														width="1600"
														height="1000"
														loading="lazy"
														decoding="async"
													/>
												</button>
											) : (
												<div class="work__shot work__shot--empty" aria-hidden="true">
													<span class="mono">{project.name}</span>
												</div>
											)}
										</figure>

										<div class="work__text">
											<div class="work__lead">
												<span class="mono work__year">{project.year}</span>
												<h3 class="work__name">
													{project.name}
													{project.featured && (
														<span class="work__star" aria-label="Destacado">
															★
														</span>
													)}
												</h3>
											</div>
											<p class="work__desc">{project.description}</p>
											{project.stack.length > 0 && (
												<p class="work__stack mono" aria-label="Tecnologías">
													{project.stack.join(' · ')}
												</p>
											)}
											{(project.repo || project.demo) && (
												<div class="work__links">
													{project.demo && (
														<a
															class="work__link"
															href={project.demo}
															target="_blank"
															rel="noopener noreferrer"
														>
															Ver demo <span aria-hidden="true">↗</span>
														</a>
													)}
													{project.repo && (
														<a
															class="work__link work__link--muted"
															href={project.repo}
															target="_blank"
															rel="noopener noreferrer"
														>
															Código <span aria-hidden="true">↗</span>
														</a>
													)}
												</div>
											)}
										</div>
									</div>
								</li>
							))
						}
					</ol>
				</section>

				<!-- ===================== 02 — STACK ===================== -->
				<section class="section" aria-labelledby="s-stack">
					<div class="section__head reveal">
						<span class="mono section__num">{sections[1].n}</span>
						<h2 class="section__title" id="s-stack">{sections[1].label}</h2>
						<span class="rule" aria-hidden="true"></span>
					</div>

					<div class="stack">
						{
							skills.map((group) => (
								<div class="stack__col reveal">
									<h3 class="stack__label mono">{group.label}</h3>
									<p class="stack__line mono">{group.items.join(' · ')}</p>
								</div>
							))
						}
					</div>
				</section>

				<!-- ===================== 03 — CONTACTO ===================== -->
				<section class="section section--contact" aria-labelledby="s-contact">
					<div class="section__head reveal">
						<span class="mono section__num">{sections[2].n}</span>
						<h2 class="section__title" id="s-contact">{sections[2].label}</h2>
						<span class="rule" aria-hidden="true"></span>
					</div>

					<div class="contact reveal">
						<span class="mono contact__kicker">Trabajemos juntos</span>
						<a class="contact__email" href={`mailto:${profile.email}`}>
							{profile.email}
						</a>
						<nav class="contact__nav" aria-label="Enlaces">
							{
								hasGithub && (
									<a
										class="mono"
										href={profile.links.github}
										target="_blank"
										rel="noopener noreferrer"
									>
										GitHub ↗
									</a>
								)
							}
							{
								hasLinkedin && (
									<a
										class="mono"
										href={profile.links.linkedin}
										target="_blank"
										rel="noopener noreferrer"
									>
										LinkedIn ↗
									</a>
								)
							}
						</nav>
					</div>
				</section>
			</main>

			<footer class="footer">
				<span class="mono muted">© {year} {profile.name}</span>
				<span class="mono muted">{profile.location}</span>
			</footer>
		</div>

		<!-- ===================== LIGHTBOX (único, reutilizado) ===================== -->
		<dialog class="lightbox" id="lightbox" aria-label="Captura ampliada">
			<button
				type="button"
				class="lightbox__close mono"
				data-lightbox-close
				aria-label="Cerrar"
			>
				✕
			</button>
			<img class="lightbox__img" id="lightbox-img" src="" alt="" width="1600" height="1000" />
		</dialog>

		<style>
			/* ================= TOKENS ================= */
			:root {
				--bg: #0d0d10;
				--surface: #141418;
				--ink: #ebe9e4;
				--ink-soft: #a4a29b;
				--ink-faint: #6d6b64;
				--hairline: rgba(255, 255, 255, 0.1);
				--hairline-soft: rgba(255, 255, 255, 0.06);
				/* Único acento: rojo ladrillo desaturado, editorial (no neón) */
				--accent: #c0654f;
				--sans: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
				--mono: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace;
				--ease: cubic-bezier(0.23, 1, 0.32, 1);
				--maxw: 72rem;
			}

			:global(html) {
				box-sizing: border-box;
				-webkit-text-size-adjust: 100%;
			}
			:global(*),
			:global(*::before),
			:global(*::after) {
				box-sizing: inherit;
			}
			:global(body) {
				margin: 0;
				background: var(--bg);
				color: var(--ink);
				font-family: var(--sans);
				font-size: 1rem;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				text-rendering: optimizeLegibility;
				overflow-x: hidden;
			}

			img {
				display: block;
				max-width: 100%;
			}

			.mono {
				font-family: var(--mono);
				font-size: 0.75rem;
				letter-spacing: 0.02em;
			}
			.muted {
				color: var(--ink-faint);
			}

			.page {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: clamp(1.75rem, 5vw, 4.5rem) clamp(1.25rem, 5vw, 4rem);
			}

			/* ================= HERO (centrado) ================= */
			.hero {
				min-height: min(84svh, 720px);
				display: grid;
				place-items: center;
				padding: clamp(3rem, 10vh, 6rem) 0 clamp(2.5rem, 8vh, 5rem);
			}
			.hero__inner {
				max-width: 42rem;
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}
			.hero__portrait {
				margin: 0;
				width: clamp(120px, 34vw, 152px);
				aspect-ratio: 1;
			}
			.hero__photo {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 50%;
				border: 1px solid var(--hairline);
				background: var(--surface);
				user-select: none;
			}
			.hero__name {
				margin: clamp(1.4rem, 4vw, 2rem) 0 0;
				font-weight: 650;
				font-size: clamp(2.6rem, 9vw, 5.25rem);
				line-height: 0.98;
				letter-spacing: -0.02em;
			}
			.hero__role {
				margin: 1rem 0 0;
				font-family: var(--mono);
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.18em;
				color: var(--accent);
			}
			.hero__tagline {
				margin: 1.15rem 0 0;
				font-size: clamp(1.02rem, 2.4vw, 1.2rem);
				line-height: 1.55;
				color: var(--ink-soft);
				max-width: 44ch;
				text-wrap: balance;
			}

			/* ================= SECTION SHELL ================= */
			.section {
				padding: clamp(2.5rem, 8vh, 5rem) 0;
			}
			.section__head {
				display: flex;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: clamp(1.75rem, 4vw, 3rem);
			}
			.section__num {
				color: var(--accent);
				flex: none;
			}
			.section__title {
				margin: 0;
				font-weight: 600;
				font-size: clamp(1.15rem, 3vw, 1.6rem);
				letter-spacing: -0.01em;
				flex: none;
			}
			.rule {
				flex: 1;
				height: 1px;
				background: var(--hairline);
				align-self: center;
			}

			/* ================= 01 — WORK (filas editoriales) ================= */
			.work {
				list-style: none;
				margin: 0;
				padding: 0;
				border-top: 1px solid var(--hairline);
			}
			.work__item {
				border-bottom: 1px solid var(--hairline);
			}
			.work__row {
				display: grid;
				grid-template-columns: 1fr;
				gap: clamp(1.1rem, 3vw, 1.5rem) clamp(2rem, 5vw, 3.5rem);
				padding: clamp(1.75rem, 4vw, 2.75rem) 0;
			}
			.work__media {
				margin: 0;
				min-width: 0;
			}
			.work__zoom {
				display: block;
				width: 100%;
				padding: 0;
				border: 0;
				margin: 0;
				background: none;
				cursor: pointer;
			}
			.work__shot {
				width: 100%;
				height: auto;
				aspect-ratio: 16 / 10;
				object-fit: cover;
				background: var(--surface);
				border: 1px solid var(--hairline);
				border-radius: 2px;
				transition: transform 240ms var(--ease), border-color 240ms var(--ease);
				will-change: transform;
			}
			.work__shot--empty {
				display: grid;
				place-items: center;
				background: repeating-linear-gradient(
					-45deg,
					transparent 0 10px,
					var(--hairline-soft) 10px 11px
				);
				color: var(--ink-faint);
				text-align: center;
				padding: 1rem;
			}
			.work__text {
				min-width: 0;
				display: grid;
				gap: 0.9rem;
				align-content: center;
			}
			.work__lead {
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}
			.work__year {
				color: var(--ink-faint);
			}
			.work__name {
				margin: 0;
				font-weight: 600;
				font-size: clamp(1.7rem, 6vw, 2.6rem);
				line-height: 1;
				letter-spacing: -0.02em;
			}
			.work__star {
				color: var(--accent);
				font-size: 0.55em;
				vertical-align: super;
				margin-left: 0.3rem;
			}
			.work__desc {
				margin: 0;
				color: var(--ink-soft);
				max-width: 42ch;
			}
			.work__stack {
				margin: 0;
				color: var(--ink-faint);
				line-height: 1.7;
			}
			.work__links {
				display: flex;
				flex-wrap: wrap;
				gap: 1.25rem;
				margin-top: 0.2rem;
			}
			.work__link {
				color: var(--accent);
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 550;
				border-bottom: 1px solid transparent;
				padding-bottom: 2px;
				transition: border-color 200ms var(--ease), color 200ms var(--ease);
			}
			.work__link--muted {
				color: var(--ink-soft);
			}
			.work__link span {
				display: inline-block;
				transition: transform 240ms var(--ease);
			}

			/* ================= 02 — STACK ================= */
			.stack {
				display: grid;
				grid-template-columns: 1fr;
				gap: clamp(1.5rem, 4vw, 2.25rem);
			}
			.stack__col {
				border-top: 1px solid var(--hairline);
				padding-top: 1rem;
			}
			.stack__label {
				margin: 0 0 0.65rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--ink-faint);
			}
			.stack__line {
				margin: 0;
				font-size: 0.9rem;
				line-height: 1.7;
				color: var(--ink);
				letter-spacing: 0.01em;
			}

			/* ================= 03 — CONTACTO ================= */
			.contact {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
			}
			.contact__kicker {
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--ink-faint);
				margin-bottom: 1rem;
			}
			.contact__email {
				margin: 0 0 clamp(1.5rem, 4vw, 2.5rem);
				font-weight: 650;
				font-size: clamp(1.75rem, 8vw, 4.25rem);
				line-height: 1;
				letter-spacing: -0.02em;
				color: var(--ink);
				text-decoration: none;
				word-break: break-word;
				transition: color 240ms var(--ease), transform 240ms var(--ease);
			}
			.contact__email:active {
				transform: scale(0.99);
			}
			.contact__nav {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1.25rem;
			}
			.contact__nav a {
				color: var(--ink);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				padding-bottom: 2px;
				transition: border-color 200ms var(--ease), color 200ms var(--ease);
			}
			.contact__nav a:active {
				color: var(--accent);
			}

			/* ================= FOOTER ================= */
			.footer {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: clamp(2rem, 5vh, 3rem) clamp(1.25rem, 5vw, 4rem);
				border-top: 1px solid var(--hairline);
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
			}

			/* ================= LIGHTBOX ================= */
			.lightbox {
				border: none;
				padding: 0;
				max-width: 90vw;
				max-height: 85vh;
				width: auto;
				background: transparent;
				overflow: visible;
			}
			.lightbox::backdrop {
				background: rgba(6, 6, 8, 0.86);
				opacity: 0;
			}
			.lightbox[open]::backdrop {
				animation: backdrop-in 220ms var(--ease) forwards;
			}
			.lightbox[open] {
				animation: lightbox-in 240ms var(--ease) forwards;
			}
			.lightbox__img {
				display: block;
				width: auto;
				height: auto;
				max-width: 90vw;
				max-height: 85vh;
				object-fit: contain;
				border-radius: 3px;
				border: 1px solid var(--hairline);
			}
			.lightbox__close {
				position: absolute;
				top: -2.75rem;
				right: 0;
				appearance: none;
				border: 1px solid var(--hairline);
				background: var(--surface);
				color: var(--ink);
				width: 2.25rem;
				height: 2.25rem;
				border-radius: 50%;
				cursor: pointer;
				display: grid;
				place-items: center;
				transition: transform 200ms var(--ease), border-color 200ms var(--ease);
			}
			.lightbox__close:active {
				transform: scale(0.97);
			}

			@keyframes lightbox-in {
				from {
					opacity: 0;
					transform: scale(0.97);
				}
				to {
					opacity: 1;
					transform: scale(1);
				}
			}
			@keyframes backdrop-in {
				to {
					opacity: 1;
				}
			}

			/* ================= HOVER (solo puntero fino) ================= */
			@media (hover: hover) and (pointer: fine) {
				.work__zoom {
					cursor: zoom-in;
				}
				.work__zoom:hover .work__shot {
					transform: scale(1.012);
					border-color: var(--hairline);
				}
				.work__link:hover {
					border-color: currentColor;
				}
				.work__link:hover span {
					transform: translate(2px, -2px);
				}
				.contact__email:hover {
					color: var(--accent);
				}
				.contact__nav a:hover {
					border-color: var(--accent);
					color: var(--accent);
				}
				.lightbox__close:hover {
					border-color: var(--ink-soft);
				}
			}

			/* pressables */
			.work__zoom:active .work__shot {
				transform: scale(0.985);
			}

			/* ================= RESPONSIVE ================= */
			@media (min-width: 48rem) {
				.work__row {
					grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
					align-items: center;
				}
				/* Alterna el lado de la captura en filas pares (editorial) */
				.work__item:nth-child(even) .work__media {
					order: 2;
				}
				.stack {
					grid-template-columns: repeat(3, 1fr);
				}
			}

			/* ================= INTRO HERO (stagger) ================= */
			.intro {
				opacity: 0;
				transform: translateY(12px);
				animation: intro-in 0.5s var(--ease) forwards;
				animation-delay: calc(var(--i) * 90ms + 80ms);
			}
			@keyframes intro-in {
				to {
					opacity: 1;
					transform: none;
				}
			}

			/* ================= REVEALS ON-SCROLL ================= */
			.reveal {
				opacity: 0;
				transform: translateY(10px);
				transition:
					opacity 0.5s var(--ease),
					transform 0.5s var(--ease);
			}
			.reveal.is-visible {
				opacity: 1;
				transform: none;
			}

			/* ================= REDUCED MOTION: solo fades ================= */
			@media (prefers-reduced-motion: reduce) {
				.intro {
					transform: none;
					animation: fade-only 0.4s var(--ease) forwards;
					animation-delay: calc(var(--i) * 60ms);
				}
				.reveal {
					transform: none;
					transition: opacity 0.4s var(--ease);
				}
				.reveal.is-visible {
					transform: none;
				}
				.work__zoom:hover .work__shot,
				.work__zoom:active .work__shot {
					transform: none;
				}
				.work__link:hover span {
					transform: none;
				}
				.contact__email:active {
					transform: none;
				}
				.lightbox[open],
				.lightbox[open]::backdrop {
					animation: fade-only 0.2s var(--ease) forwards;
				}
			}
			@keyframes fade-only {
				to {
					opacity: 1;
				}
			}
		</style>

		<script>
			// ---------- Reveals on-scroll (una sola vez, con stagger entre hermanos) ----------
			const items = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
			if ('IntersectionObserver' in window && items.length) {
				const io = new IntersectionObserver(
					(entries, obs) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							const el = entry.target as HTMLElement;
							const siblings = Array.from(
								el.parentElement?.querySelectorAll(':scope > .reveal') ?? []
							);
							const idx = Math.max(0, siblings.indexOf(el));
							el.style.transitionDelay = `${Math.min(idx * 50, 250)}ms`;
							el.classList.add('is-visible');
							obs.unobserve(el);
						});
					},
					{ threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
				);
				items.forEach((el) => io.observe(el));
			} else {
				items.forEach((el) => el.classList.add('is-visible'));
			}

			// ---------- Lightbox (un único <dialog> reutilizado) ----------
			const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
			const dialogImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

			if (dialog && dialogImg) {
				const openZoom = (src: string, caption: string) => {
					dialogImg.src = src;
					dialogImg.alt = `Captura ampliada de ${caption}`;
					if (typeof dialog.showModal === 'function') dialog.showModal();
				};

				document.querySelectorAll<HTMLButtonElement>('[data-zoom]').forEach((btn) => {
					btn.addEventListener('click', () => {
						openZoom(btn.dataset.src ?? '', btn.dataset.caption ?? '');
					});
				});

				// Cerrar con botón ✕
				dialog
					.querySelector('[data-lightbox-close]')
					?.addEventListener('click', () => dialog.close());

				// Cerrar clickeando el backdrop (fuera de la imagen)
				dialog.addEventListener('click', (e) => {
					if (e.target === dialog) dialog.close();
				});

				// Limpiar src al cerrar (Escape ya funciona nativo en <dialog>)
				dialog.addEventListener('close', () => {
					dialogImg.src = '';
				});
			}
		</script>
	</body>
</html>
