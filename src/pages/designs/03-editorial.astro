---
// ============================================================
// Maqueta 03 — "Editorial"
// Minimalismo suizo, tema CLARO. Publicación impresa bien diagramada.
// Todo el contenido sale de src/data/profile.ts (fuente única de verdad).
// Página autocontenida: estilos propios, sin CSS global.
// ============================================================
import { profile, projects, skills } from '../../data/profile';

const year = new Date().getFullYear();

const sections = [
	{ n: '01', label: 'Sobre mí' },
	{ n: '02', label: 'Proyectos' },
	{ n: '03', label: 'Stack' },
];

const metaDescription = `Portfolio de ${profile.name} (${profile.handle}), ${profile.role}. ${profile.tagline}`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={metaDescription} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<script is:inline>
			// Anti-FOUC: fija data-theme antes del primer paint.
			(function () {
				try {
					var stored = localStorage.getItem('theme');
					var theme =
						stored ||
						(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
					document.documentElement.setAttribute('data-theme', theme);
				} catch (e) {
					document.documentElement.setAttribute('data-theme', 'light');
				}
			})();
		</script>
		<title>{profile.name} — {profile.role} · Editorial</title>
	</head>
	<body>
		<button
			class="theme-toggle mono"
			type="button"
			aria-label="Cambiar entre tema claro y oscuro"
		>
			<svg
				class="theme-toggle__sun"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				aria-hidden="true"
			>
				<circle cx="12" cy="12" r="4"></circle>
				<path
					d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
				></path>
			</svg>
			<svg
				class="theme-toggle__moon"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
			</svg>
		</button>
		<div class="page">
			<!-- ===================== HERO ===================== -->
			<header class="hero">
				<figure class="hero__portrait reveal">
					<img
						class="hero__photo"
						src={profile.avatar}
						alt={`Retrato de ${profile.name}`}
						width="400"
						height="400"
						decoding="async"
						fetchpriority="high"
					/>
				</figure>

				<div class="hero__text reveal">
					<h1 class="display">{profile.name}</h1>
					<p class="role mono">{profile.role}</p>
					<p class="tagline">{profile.tagline}</p>
				</div>
			</header>

			<main>
				<!-- ===================== 01 — SOBRE MÍ ===================== -->
				<section class="section" aria-labelledby="s-about">
					<div class="section__head reveal">
						<span class="mono section__num">{sections[0].n}</span>
						<h2 class="section__title" id="s-about">{sections[0].label}</h2>
						<span class="rule" aria-hidden="true"></span>
					</div>
					<div class="about reveal">
						<p class="about__lede">{profile.about}</p>
					</div>
				</section>

				<!-- ===================== 02 — PROYECTOS ===================== -->
				<section class="section" aria-labelledby="s-work">
					<div class="section__head reveal">
						<span class="mono section__num">{sections[1].n}</span>
						<h2 class="section__title" id="s-work">{sections[1].label}</h2>
						<span class="rule" aria-hidden="true"></span>
					</div>

					<ol class="work">
						{
							projects.map((project) => {
								const href = project.demo ?? project.repo;
								const Tag = href ? 'a' : 'div';
								return (
									<li class="work__item reveal">
										<Tag
											class="work__row"
											{...(href
												? {
														href,
														target: '_blank',
														rel: 'noopener noreferrer',
													}
												: {})}
										>
											<figure class="work__media">
												{project.image ? (
													<img
														class="work__shot"
														src={project.image}
														alt={`Captura de ${project.name}`}
														width="1600"
														height="1000"
														loading="lazy"
														decoding="async"
														data-zoom
													/>
												) : (
													<div class="work__shot work__shot--empty" aria-hidden="true">
														<span class="mono">{project.name}</span>
													</div>
												)}
											</figure>
											<div class="work__text">
												<div class="work__lead">
													<span class="mono work__year">{project.year}</span>
													<h3 class="work__name">
														{project.name}
														{project.featured && (
															<span class="work__star mono" aria-label="Destacado">
																★
															</span>
														)}
													</h3>
												</div>
												<div class="work__body">
													<p class="work__desc">{project.description}</p>
													<ul class="work__stack">
														{project.stack.map((tech) => (
															<li class="mono">{tech}</li>
														))}
													</ul>
												</div>
											</div>
										</Tag>
									</li>
								);
							})
						}
					</ol>
				</section>

				<!-- ===================== 03 — STACK ===================== -->
				<section class="section" aria-labelledby="s-stack">
					<div class="section__head reveal">
						<span class="mono section__num">{sections[2].n}</span>
						<h2 class="section__title" id="s-stack">{sections[2].label}</h2>
						<span class="rule" aria-hidden="true"></span>
					</div>

					<div class="stack">
						{
							skills.map((group) => (
								<div class="stack__col reveal">
									<h3 class="stack__label mono">{group.label}</h3>
									<ul class="stack__list">
										{group.items.map((item) => (
											<li>{item}</li>
										))}
									</ul>
								</div>
							))
						}
					</div>
				</section>
			</main>

			<!-- ===================== FOOTER ===================== -->
			<footer class="footer">
				<span class="mono footer__kicker reveal">Trabajemos juntos</span>
				<a class="footer__email reveal" href={`mailto:${profile.email}`}>{profile.email}</a>
				<nav class="footer__nav reveal" aria-label="Enlaces">
					{
						profile.links.github && (
							<a
								class="mono"
								href={profile.links.github}
								target="_blank"
								rel="noopener noreferrer"
							>
								GitHub ↗
							</a>
						)
					}
					{
						profile.links.linkedin && (
							<a
								class="mono"
								href={profile.links.linkedin}
								target="_blank"
								rel="noopener noreferrer"
							>
								LinkedIn ↗
							</a>
						)
					}
					<span class="mono muted footer__copy">© {year} {profile.name}</span>
				</nav>
			</footer>
		</div>

		<!-- ===================== LIGHTBOX ===================== -->
		<dialog class="lightbox" aria-label="Captura ampliada">
			<button class="lightbox__close" type="button" aria-label="Cerrar captura ampliada">
				✕
			</button>
			<img class="lightbox__img" src="" alt="" decoding="async" />
		</dialog>

		<style>
			/* ================= TOKENS ================= */
			:global(:root) {
				/* Tema claro (por defecto) */
				--paper: #faf9f7;
				--ink: #1a1a1a;
				--ink-soft: #4a4744;
				--ink-faint: #6f6a63;
				--hairline: #e2ddd6;
				--surface: #ffffff;
				--accent: #d43425; /* rojo suizo, con muchísima moderación */
				--scrim: rgba(20, 18, 16, 0.72);
				--serif: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
				--mono: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace;
				--ease: cubic-bezier(0.23, 1, 0.32, 1);
				color-scheme: light;
			}

			/* Tema oscuro: papel casi negro cálido, tinta clara, rojo ajustado a AA */
			:global(:root[data-theme='dark']) {
				--paper: #121110;
				--ink: #eae7e2;
				--ink-soft: #b7b1a8;
				--ink-faint: #928c83;
				--hairline: rgba(234, 231, 226, 0.12);
				--surface: #1d1b19;
				--accent: #ff6f5e;
				--scrim: rgba(0, 0, 0, 0.78);
				color-scheme: dark;
			}

			/* Transición de tema barata: solo colores, 200ms */
			:global(:root:not([data-theme])) {
				color-scheme: light dark;
			}

			:global(html) {
				box-sizing: border-box;
				-webkit-text-size-adjust: 100%;
			}
			:global(*),
			:global(*::before),
			:global(*::after) {
				box-sizing: inherit;
			}
			:global(body) {
				margin: 0;
				background: var(--paper);
				color: var(--ink);
				font-family: var(--serif);
				font-size: 1rem;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				text-rendering: optimizeLegibility;
				overflow-x: hidden;
				transition:
					background-color 200ms ease,
					color 200ms ease;
			}
			/* Cambio de tema: transicionar solo colores en superficies con borde/fondo */
			.rule,
			.work,
			.work__item,
			.work__shot,
			.hero__photo,
			.stack__col,
			.footer,
			.footer__nav a,
			.theme-toggle {
				transition:
					background-color 200ms ease,
					border-color 200ms ease,
					color 200ms ease;
			}

			.mono {
				font-family: var(--mono);
				font-size: 0.75rem;
				letter-spacing: 0.02em;
			}
			.muted {
				color: var(--ink-faint);
			}

			.page {
				max-width: 72rem;
				margin: 0 auto;
				padding: clamp(1.75rem, 5vw, 4.5rem) clamp(1.25rem, 5vw, 4rem);
			}

			/* ================= HERO ================= */
			/* Layout horizontal: foto a la izquierda, texto apilado a la derecha.
			   En mobile colapsa a columna (foto arriba, texto abajo). */
			.hero {
				padding: clamp(2rem, 8vh, 6rem) 0 clamp(2.5rem, 6vh, 4rem);
				display: grid;
				grid-template-columns: 1fr;
				gap: clamp(1.5rem, 5vw, 2.75rem);
				align-items: center;
			}
			.hero__portrait {
				margin: 0;
			}
			.hero__photo {
				display: block;
				width: clamp(10rem, 42vw, 16rem);
				height: auto;
				aspect-ratio: 1 / 1;
				object-fit: cover;
				background: var(--surface);
				border: 1px solid var(--ink);
				border-radius: 3px;
				padding: 6px;
				user-select: none;
			}

			.hero__text {
				display: grid;
				gap: clamp(0.6rem, 2vw, 1rem);
				align-content: center;
				min-width: 0;
			}

			.display {
				margin: 0;
				font-weight: 700;
				font-size: clamp(2.75rem, 9vw, 5.5rem);
				line-height: 0.95;
				letter-spacing: -0.02em;
			}
			.role {
				margin: 0;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--accent);
			}
			.tagline {
				margin: 0.25rem 0 0;
				font-size: clamp(1.05rem, 2.4vw, 1.35rem);
				line-height: 1.5;
				color: var(--ink-soft);
				max-width: 34rem;
			}

			/* ================= SECTION SHELL ================= */
			.section {
				padding: clamp(2.5rem, 8vh, 5rem) 0;
			}
			.section__head {
				display: flex;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: clamp(1.5rem, 4vw, 2.75rem);
			}
			.section__num {
				color: var(--accent);
				flex: none;
			}
			.section__title {
				margin: 0;
				font-weight: 600;
				font-size: clamp(1.15rem, 3vw, 1.6rem);
				letter-spacing: -0.01em;
				flex: none;
			}
			.rule {
				flex: 1;
				height: 1px;
				background: var(--ink);
				align-self: center;
				transform-origin: left;
			}

			/* ================= 01 — ABOUT ================= */
			.about {
				max-width: 46rem;
			}
			.about__lede {
				margin: 0;
				font-size: clamp(1.25rem, 3vw, 1.9rem);
				line-height: 1.4;
				letter-spacing: -0.01em;
				font-weight: 400;
			}

			/* ================= 02 — WORK ================= */
			.work {
				list-style: none;
				margin: 0;
				padding: 0;
				border-top: 1px solid var(--hairline);
			}
			.work__item {
				border-bottom: 1px solid var(--hairline);
			}
			.work__row {
				display: grid;
				grid-template-columns: 1fr;
				gap: clamp(1rem, 3vw, 1.5rem) clamp(2rem, 5vw, 3.5rem);
				padding: clamp(1.5rem, 4vw, 2.5rem) 0;
				color: inherit;
				text-decoration: none;
				transition: transform 240ms var(--ease);
				will-change: transform;
			}
			/* Captura del proyecto (evidencia del trabajo) */
			.work__media {
				margin: 0;
				min-width: 0;
			}
			.work__shot {
				display: block;
				width: 100%;
				height: auto;
				aspect-ratio: 16 / 10;
				object-fit: cover;
				background: var(--surface);
				border: 1px solid var(--hairline);
				border-radius: 2px;
			}
			/* Affordance de ampliar (solo puntero fino) */
			.work__shot[data-zoom] {
				cursor: zoom-in;
			}
			@media (hover: hover) and (pointer: fine) {
				.work__shot[data-zoom] {
					transition:
						opacity 200ms var(--ease),
						border-color 200ms ease;
				}
				.work__shot[data-zoom]:hover {
					opacity: 0.92;
					border-color: var(--accent);
				}
			}
			.work__shot--empty {
				display: grid;
				place-items: center;
				background: repeating-linear-gradient(
					-45deg,
					transparent 0 10px,
					var(--hairline) 10px 11px
				);
				color: var(--ink-faint);
				text-align: center;
				padding: 1rem;
			}
			.work__text {
				min-width: 0;
				display: grid;
				gap: 0.9rem;
				align-content: start;
			}
			.work__lead {
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}
			.work__year {
				color: var(--ink-faint);
			}
			.work__name {
				margin: 0;
				font-weight: 600;
				font-size: clamp(1.6rem, 6vw, 2.6rem);
				line-height: 1;
				letter-spacing: -0.02em;
				transition: color 240ms var(--ease);
			}
			.work__star {
				color: var(--accent);
				font-size: 0.8em;
				vertical-align: super;
				margin-left: 0.25rem;
			}
			.work__body {
				max-width: 34rem;
			}
			.work__desc {
				margin: 0 0 1rem;
				color: var(--ink-soft);
			}
			.work__stack {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem 0.75rem;
			}
			.work__stack li {
				color: var(--ink-faint);
			}
			.work__stack li::before {
				content: '·';
				margin-right: 0.75rem;
				color: var(--hairline);
			}
			.work__stack li:first-child::before {
				content: none;
			}

			/* ================= 03 — STACK ================= */
			.stack {
				display: grid;
				grid-template-columns: 1fr;
				gap: clamp(2rem, 5vw, 3rem);
			}
			.stack__col {
				border-top: 1px solid var(--ink);
				padding-top: 1rem;
			}
			.stack__label {
				margin: 0 0 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--ink-faint);
			}
			.stack__list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.35rem;
			}
			.stack__list li {
				font-size: 1.05rem;
			}

			/* ================= FOOTER ================= */
			.footer {
				padding: clamp(3rem, 10vh, 6rem) 0 clamp(2rem, 5vh, 3rem);
				border-top: 1px solid var(--ink);
				margin-top: clamp(2rem, 6vh, 4rem);
			}
			.footer__kicker {
				display: block;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--ink-faint);
				margin-bottom: 1rem;
			}
			.footer__email {
				display: inline-block;
				margin: 0 0 clamp(1.5rem, 4vw, 2.5rem);
				font-weight: 700;
				font-size: clamp(1.75rem, 8vw, 4.5rem);
				line-height: 1;
				letter-spacing: -0.02em;
				color: var(--ink);
				text-decoration: none;
				word-break: break-word;
				transition: color 240ms var(--ease), transform 240ms var(--ease);
			}
			.footer__email:active {
				transform: scale(0.99);
			}
			.footer__nav {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1.25rem;
			}
			.footer__nav a {
				color: var(--ink);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				padding-bottom: 2px;
				transition: border-color 200ms var(--ease), color 200ms var(--ease);
			}
			.footer__nav a:active {
				color: var(--accent);
			}
			.footer__copy {
				margin-left: auto;
			}

			/* ================= HOVER (solo desktop) ================= */
			@media (hover: hover) and (pointer: fine) {
				a.work__row:hover {
					transform: translateX(4px);
				}
				a.work__row:hover .work__name {
					color: var(--accent);
				}
				.footer__email:hover {
					color: var(--accent);
				}
				.footer__nav a:hover {
					border-color: var(--accent);
					color: var(--accent);
				}
			}

			/* feedback :active en filas pressables */
			a.work__row:active {
				transform: translateX(2px);
			}

			/* ================= RESPONSIVE ================= */
			@media (min-width: 48rem) {
				.hero {
					grid-template-columns: auto minmax(0, 1fr);
					gap: clamp(2rem, 5vw, 4rem);
					align-items: center;
				}
				.work__row {
					grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
					align-items: center;
				}
				/* Alterna el lado de la captura en filas pares (editorial) */
				.work__item:nth-child(even) .work__media {
					order: 2;
				}
				.stack {
					grid-template-columns: repeat(3, 1fr);
				}
			}

			/* ================= THEME TOGGLE ================= */
			.theme-toggle {
				position: fixed;
				top: clamp(0.85rem, 2.5vw, 1.5rem);
				right: clamp(0.85rem, 2.5vw, 1.5rem);
				z-index: 20;
				display: inline-grid;
				place-items: center;
				width: 2.4rem;
				height: 2.4rem;
				padding: 0;
				color: var(--ink);
				background: var(--paper);
				border: 1px solid var(--hairline);
				border-radius: 999px;
				cursor: pointer;
				-webkit-tap-highlight-color: transparent;
			}
			.theme-toggle svg {
				display: block;
				grid-area: 1 / 1;
			}
			/* Muestra el icono del tema activo */
			.theme-toggle__moon {
				display: none;
			}
			:global(:root[data-theme='dark']) .theme-toggle__sun {
				display: none;
			}
			:global(:root[data-theme='dark']) .theme-toggle__moon {
				display: block;
			}
			.theme-toggle:active {
				transform: scale(0.94);
			}
			.theme-toggle:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			@media (hover: hover) and (pointer: fine) {
				.theme-toggle:hover {
					border-color: var(--accent);
					color: var(--accent);
				}
			}

			/* ================= LIGHTBOX ================= */
			.lightbox {
				margin: auto;
				padding: 0;
				border: none;
				background: transparent;
				width: fit-content;
				height: fit-content;
				max-width: 90vw;
				max-height: 85vh;
				overflow: visible;
			}
			.lightbox::backdrop {
				background: var(--scrim);
			}
			.lightbox__img {
				display: block;
				max-width: 90vw;
				max-height: 85vh;
				width: auto;
				height: auto;
				border-radius: 3px;
				box-shadow: 0 24px 70px rgba(0, 0, 0, 0.5);
			}
			.lightbox__close {
				position: absolute;
				top: 0.5rem;
				right: 0.5rem;
				width: 2.2rem;
				height: 2.2rem;
				display: grid;
				place-items: center;
				font-size: 0.9rem;
				line-height: 1;
				color: var(--ink);
				background: var(--paper);
				border: 1px solid var(--hairline);
				border-radius: 999px;
				cursor: pointer;
				-webkit-tap-highlight-color: transparent;
			}
			.lightbox__close:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			@media (hover: hover) and (pointer: fine) {
				.lightbox__close:hover {
					border-color: var(--accent);
					color: var(--accent);
				}
			}
			/* Entrada: fade + scale, curva editorial, <=250ms */
			.lightbox[open] {
				animation: lb-in 240ms var(--ease);
			}
			.lightbox[open]::backdrop {
				animation: lb-fade 240ms ease;
			}
			@keyframes lb-in {
				from {
					opacity: 0;
					transform: scale(0.97);
				}
				to {
					opacity: 1;
					transform: none;
				}
			}
			@keyframes lb-fade {
				from {
					opacity: 0;
				}
				to {
					opacity: 1;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.lightbox[open] {
					animation: lb-fade 200ms ease;
				}
			}

			/* ================= REVEALS ================= */
			.reveal {
				opacity: 0;
				transform: translateY(10px);
				transition:
					opacity 300ms var(--ease),
					transform 300ms var(--ease);
			}
			.reveal.is-visible {
				opacity: 1;
				transform: none;
			}

			@media (prefers-reduced-motion: reduce) {
				.reveal {
					transform: none;
					transition: opacity 300ms ease;
				}
				.work__row,
				.work__name,
				.footer__email,
				.footer__nav a {
					transition: color 200ms ease;
				}
				a.work__row:hover,
				a.work__row:active {
					transform: none;
				}
			}
		</style>

		<script>
			// ---------- Toggle de tema (persistencia en localStorage) ----------
			const root = document.documentElement;
			const toggle = document.querySelector('.theme-toggle');
			toggle?.addEventListener('click', () => {
				const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
				root.setAttribute('data-theme', next);
				try {
					localStorage.setItem('theme', next);
				} catch (e) {
					/* almacenamiento no disponible */
				}
			});

			// ---------- Lightbox: un solo <dialog> reutilizado ----------
			const dialog = document.querySelector('.lightbox') as HTMLDialogElement | null;
			const dialogImg = dialog?.querySelector('.lightbox__img') as HTMLImageElement | null;
			const dialogClose = dialog?.querySelector('.lightbox__close') as HTMLButtonElement | null;

			if (dialog && dialogImg) {
				document.querySelectorAll('.work__shot[data-zoom]').forEach((shot) => {
					shot.addEventListener('click', (event) => {
						// La captura vive dentro del link de la fila: evitá navegar.
						event.preventDefault();
						event.stopPropagation();
						const img = shot as HTMLImageElement;
						dialogImg.src = img.currentSrc || img.src;
						dialogImg.alt = img.alt;
						dialog.showModal();
					});
				});

				dialogClose?.addEventListener('click', () => dialog.close());

				// Click en el backdrop (área fuera de la imagen) cierra.
				dialog.addEventListener('click', (event) => {
					if (event.target === dialog) dialog.close();
				});

				// Limpia el src al cerrar (Escape incluido, nativo del dialog).
				dialog.addEventListener('close', () => {
					dialogImg.removeAttribute('src');
				});
			}

			const items = Array.from(document.querySelectorAll('.reveal'));

			if (!('IntersectionObserver' in window)) {
				items.forEach((el) => el.classList.add('is-visible'));
			} else {
				const io = new IntersectionObserver(
					(entries, obs) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							const el = entry.target as HTMLElement;
							// stagger sutil entre hermanos revelados juntos
							const siblings = Array.from(
								el.parentElement?.querySelectorAll(':scope > .reveal') ?? [],
							);
							const idx = Math.max(0, siblings.indexOf(el));
							el.style.transitionDelay = `${Math.min(idx * 50, 250)}ms`;
							el.classList.add('is-visible');
							obs.unobserve(el);
						});
					},
					{ threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
				);
				items.forEach((el) => io.observe(el));
			}
		</script>
	</body>
</html>
