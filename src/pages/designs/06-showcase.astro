---
// ============================================================
// Diseño 06 — "Showcase"
// La captura como protagonista: proyectos en carrusel horizontal
// con tarjetas grandes. Sobrio, oscuro, un único acento azul acero.
// Fuente única de contenido: src/data/profile.ts (cero texto hardcodeado).
// Página autocontenida: estilos y scripts propios, sin CSS global.
// ============================================================
import { profile, projects, skills } from '../../data/profile';

const initial = profile.name.trim().charAt(0).toUpperCase();
const hasGithub = profile.links.github.length > 0;
const hasLinkedin = profile.links.linkedin.length > 0;
const metaDescription = `${profile.name} — ${profile.role}. ${profile.tagline}`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={metaDescription} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{profile.name} — {profile.role}</title>
	</head>
	<body>
		<main>
			<!-- HERO -->
			<section class="hero" aria-labelledby="hero-name">
				<div class="hero__inner">
					<div class="hero__avatar intro" style="--i: 0">
						<img
							src={profile.avatar}
							alt={`Foto de ${profile.name}`}
							width="160"
							height="160"
							decoding="async"
						/>
					</div>
					<h1 id="hero-name" class="hero__name intro" style="--i: 1">
						{profile.name}
					</h1>
					<p class="hero__role intro" style="--i: 2">
						{profile.role}
					</p>
					<p class="hero__tagline intro" style="--i: 3">
						{profile.tagline}
					</p>
				</div>
			</section>

			<!-- PROYECTOS -->
			<section class="work" aria-labelledby="work-title">
				<header class="section-head" data-reveal>
					<p class="section-head__eyebrow">Trabajo</p>
					<h2 id="work-title" class="section-head__title">Proyectos</h2>
				</header>

				<div class="carousel" data-reveal style="--reveal-delay: 60ms">
					<ul
						class="carousel__track"
						id="carousel-track"
						aria-label="Proyectos, desplazá horizontalmente"
					>
						{
							projects.map((project, i) => (
								<li
									class="card"
									id={`card-${i}`}
									data-index={i}
								>
									<figure class="card__media">
										{project.image ? (
											<button
												type="button"
												class="card__zoom"
												data-zoom-src={project.image}
												data-zoom-alt={`Captura del proyecto ${project.name}`}
												aria-label={`Ampliar captura de ${project.name}`}
											>
												<img
													src={project.image}
													alt={`Captura del proyecto ${project.name}`}
													width="1600"
													height="1000"
													loading="lazy"
													decoding="async"
												/>
											</button>
										) : (
											<div class="card__fallback" aria-hidden="true">
												<span>{project.name.charAt(0).toUpperCase()}</span>
											</div>
										)}
									</figure>
									<div class="card__body">
										<div class="card__heading">
											<h3 class="card__name">{project.name}</h3>
											{project.year && (
												<span class="card__year">{project.year}</span>
											)}
										</div>
										<p class="card__desc">{project.description}</p>
										{project.stack.length > 0 && (
											<p class="card__stack" aria-label="Tecnologías">
												{project.stack.join(' · ')}
											</p>
										)}
										{(project.repo || project.demo) && (
											<div class="card__links">
												{project.demo && (
													<a
														class="link"
														href={project.demo}
														target="_blank"
														rel="noopener noreferrer"
													>
														Ver demo
														<span aria-hidden="true">↗</span>
													</a>
												)}
												{project.repo && (
													<a
														class="link link--muted"
														href={project.repo}
														target="_blank"
														rel="noopener noreferrer"
													>
														Código
														<span aria-hidden="true">↗</span>
													</a>
												)}
											</div>
										)}
									</div>
								</li>
							))
						}
					</ul>

					{
						projects.length > 1 && (
							<button
								type="button"
								class="carousel__arrow carousel__arrow--prev"
								data-prev
								aria-label="Proyecto anterior"
								disabled
							>
								<svg
									width="18"
									height="18"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M15 18l-6-6 6-6" />
								</svg>
							</button>
						)
					}
					{
						projects.length > 1 && (
							<button
								type="button"
								class="carousel__arrow carousel__arrow--next"
								data-next
								aria-label="Proyecto siguiente"
							>
								<svg
									width="18"
									height="18"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M9 6l6 6-6 6" />
								</svg>
							</button>
						)
					}
					{
						projects.length > 1 && (
							<div class="dots" role="group" aria-label="Ir al proyecto">
								{projects.map((project, i) => (
									<button
										type="button"
										class="dots__dot"
										data-dot={i}
										aria-label={`Ir a ${project.name}`}
										aria-current={i === 0 ? 'true' : undefined}
									/>
								))}
							</div>
						)
					}
				</div>
			</section>

			<!-- SKILLS -->
			<section class="skills" aria-labelledby="skills-title">
				<header class="section-head" data-reveal>
					<p class="section-head__eyebrow">Stack</p>
					<h2 id="skills-title" class="section-head__title">Herramientas</h2>
				</header>
				<div class="skills__grid">
					{
						skills.map((group, i) => (
							<div
								class="skill-group"
								data-reveal
								style={`--reveal-delay: ${i * 50}ms`}
							>
								<p class="skill-group__label">{group.label}</p>
								<p class="skill-group__items">{group.items.join(' · ')}</p>
							</div>
						))
					}
				</div>
			</section>

			<!-- FOOTER -->
			<footer class="footer" aria-labelledby="footer-title">
				<div class="footer__inner" data-reveal>
					<p class="footer__eyebrow">Contacto</p>
					<h2 id="footer-title" class="footer__title">
						¿Trabajamos juntos?
					</h2>
					<a class="footer__cta" href={`mailto:${profile.email}`}>
						{profile.email}
					</a>
					<div class="footer__links">
						{
							hasGithub && (
								<a
									href={profile.links.github}
									target="_blank"
									rel="noopener noreferrer"
								>
									GitHub
								</a>
							)
						}
						{
							hasLinkedin && (
								<a
									href={profile.links.linkedin}
									target="_blank"
									rel="noopener noreferrer"
								>
									LinkedIn
								</a>
							)
						}
					</div>
					<p class="footer__meta">
						<span>{profile.location}</span>
						<span aria-hidden="true">·</span>
						<span>{profile.handle}</span>
					</p>
				</div>
			</footer>
		</main>

		<!-- LIGHTBOX (único, reutilizado por JS) -->
		<dialog class="lightbox" id="lightbox" aria-label="Vista ampliada de la captura">
			<button
				type="button"
				class="lightbox__close"
				data-lightbox-close
				aria-label="Cerrar"
			>
				<span aria-hidden="true">✕</span>
			</button>
			<img
				class="lightbox__img"
				id="lightbox-img"
				alt=""
				width="1600"
				height="1000"
				decoding="async"
			/>
		</dialog>

		<style>
			:root {
				--bg: #0c0d10;
				--surface: #131519;
				--surface-2: #191c22;
				--border: rgba(255, 255, 255, 0.08);
				--border-strong: rgba(255, 255, 255, 0.14);
				--text: #eef0f4;
				--text-2: #a2a8b4;
				--text-3: #6b7180;
				/* Acento: azul acero desaturado, frío y elegante */
				--accent: #7ba7cf;
				--accent-soft: rgba(123, 167, 207, 0.14);
				--ease: cubic-bezier(0.23, 1, 0.32, 1);
				--maxw: 1120px;
			}

			* {
				box-sizing: border-box;
			}

			:global(html) {
				scroll-behavior: smooth;
			}

			:global(body) {
				margin: 0;
				background: var(--bg);
				color: var(--text);
				font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				text-rendering: optimizeLegibility;
				overflow-x: hidden;
			}

			img {
				display: block;
				max-width: 100%;
			}

			ul {
				margin: 0;
				padding: 0;
				list-style: none;
			}

			/* ---------- HERO ---------- */
			.hero {
				min-height: min(88svh, 780px);
				display: grid;
				place-items: center;
				padding: 6rem 1.5rem 4rem;
				position: relative;
			}

			.hero::after {
				content: '';
				position: absolute;
				top: -10%;
				left: 50%;
				width: min(680px, 90vw);
				height: 420px;
				transform: translateX(-50%);
				background: radial-gradient(
					ellipse at center,
					var(--accent-soft),
					transparent 68%
				);
				filter: blur(20px);
				pointer-events: none;
				z-index: 0;
			}

			.hero__inner {
				position: relative;
				z-index: 1;
				max-width: 640px;
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.hero__avatar {
				width: clamp(120px, 34vw, 160px);
				aspect-ratio: 1;
				border-radius: 50%;
				overflow: hidden;
				border: 1px solid var(--border-strong);
				box-shadow:
					0 0 0 6px rgba(255, 255, 255, 0.02),
					0 22px 60px -28px rgba(0, 0, 0, 0.9);
			}

			.hero__avatar img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.hero__name {
				margin: 1.6rem 0 0;
				font-size: clamp(2.4rem, 8vw, 4.6rem);
				line-height: 1.02;
				letter-spacing: -0.02em;
				font-weight: 650;
			}

			.hero__role {
				margin: 0.9rem 0 0;
				font-size: 0.82rem;
				text-transform: uppercase;
				letter-spacing: 0.18em;
				color: var(--accent);
				font-weight: 600;
			}

			.hero__tagline {
				margin: 1.1rem 0 0;
				font-size: clamp(1rem, 2.4vw, 1.15rem);
				color: var(--text-2);
				max-width: 46ch;
				text-wrap: balance;
			}

			/* ---------- SECCIONES ---------- */
			.work,
			.skills {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: 4rem 0;
			}

			.section-head {
				padding: 0 1.5rem;
				margin-bottom: 2rem;
			}

			.section-head__eyebrow {
				margin: 0 0 0.5rem;
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				color: var(--text-3);
				font-weight: 600;
			}

			.section-head__title {
				margin: 0;
				font-size: clamp(1.7rem, 4vw, 2.4rem);
				letter-spacing: -0.02em;
				font-weight: 640;
			}

			/* ---------- CARRUSEL ---------- */
			.carousel {
				position: relative;
			}

			.carousel__track {
				/* Una tarjeta protagonista por vista. El peek (asomo de la
				   tarjeta vecina) se obtiene con padding simétrico = mitad del
				   espacio libre, de modo que la 1ª/última tarjeta también
				   queden centradas y el snap por centro nunca desalinee. */
				--card-w: min(1040px, 90vw);
				display: flex;
				gap: 1.25rem;
				overflow-x: auto;
				overflow-y: hidden;
				scroll-snap-type: x mandatory;
				padding: 0.5rem calc((100% - var(--card-w)) / 2) 1.25rem;
				scrollbar-width: none;
				-webkit-overflow-scrolling: touch;
				overscroll-behavior-x: contain;
			}

			.carousel__track::-webkit-scrollbar {
				display: none;
			}

			.card {
				flex: 0 0 var(--card-w);
				width: var(--card-w);
				scroll-snap-align: center;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 18px;
				overflow: hidden;
				display: flex;
				flex-direction: column;
			}

			.card__media {
				margin: 0;
				aspect-ratio: 16 / 10;
				background: var(--surface-2);
				overflow: hidden;
			}

			.card__media img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			/* Botón que envuelve la captura para abrir el lightbox */
			.card__zoom {
				display: block;
				width: 100%;
				height: 100%;
				margin: 0;
				padding: 0;
				border: none;
				background: none;
				cursor: pointer;
				color: inherit;
			}

			.card__zoom img {
				transition: transform 0.3s var(--ease);
			}

			.card__zoom:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: -3px;
			}

			.card__fallback {
				width: 100%;
				height: 100%;
				display: grid;
				place-items: center;
				background:
					radial-gradient(
						ellipse at 30% 25%,
						var(--accent-soft),
						transparent 60%
					),
					var(--surface-2);
			}

			.card__fallback span {
				font-size: clamp(3rem, 12vw, 5rem);
				font-weight: 700;
				color: var(--text-3);
				letter-spacing: -0.03em;
			}

			.card__body {
				padding: 1.4rem 1.4rem 1.6rem;
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
				border-top: 1px solid var(--border);
			}

			.card__heading {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
			}

			.card__name {
				margin: 0;
				font-size: 1.25rem;
				letter-spacing: -0.01em;
				font-weight: 640;
			}

			.card__year {
				font-size: 0.78rem;
				color: var(--text-3);
				font-variant-numeric: tabular-nums;
				flex: none;
			}

			.card__desc {
				margin: 0;
				color: var(--text-2);
				font-size: 0.95rem;
				max-width: 60ch;
			}

			/* Stack tecnológico: tipografía mono, sin pastillas */
			.card__stack {
				margin: 0;
				font-family: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, Consolas,
					monospace;
				font-size: 0.78rem;
				letter-spacing: 0.02em;
				color: var(--text-3);
			}

			.card__links {
				display: flex;
				gap: 1.2rem;
				margin-top: 0.2rem;
			}

			.link {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				color: var(--accent);
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 550;
				transition: opacity 0.2s var(--ease);
			}

			.link span {
				transition: transform 0.24s var(--ease);
			}

			.link--muted {
				color: var(--text-2);
			}

			/* ---------- FLECHAS ---------- */
			/* Solo visibles con puntero fino: en táctil el swipe es el gesto
			   natural y las flechas serían ruido. */
			.carousel__arrow {
				position: absolute;
				top: 38%;
				z-index: 2;
				width: 2.75rem;
				height: 2.75rem;
				display: none;
				place-items: center;
				border-radius: 999px;
				border: 1px solid var(--border-strong);
				background: rgba(19, 21, 25, 0.78);
				backdrop-filter: blur(8px);
				color: var(--text);
				cursor: pointer;
				transition:
					transform 0.16s var(--ease),
					background-color 0.2s var(--ease),
					opacity 0.2s var(--ease);
			}

			.carousel__arrow--prev {
				left: 0.9rem;
			}

			.carousel__arrow--next {
				right: 0.9rem;
			}

			.carousel__arrow:disabled {
				opacity: 0.3;
				cursor: default;
			}

			.carousel__arrow:not(:disabled):active {
				transform: scale(0.94);
			}

			.carousel__arrow:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}

			/* ---------- DOTS ---------- */
			.dots {
				display: flex;
				justify-content: center;
				gap: 0.15rem;
				padding: 0.25rem 1.5rem 0;
			}

			/* El dot visible mide 7px pero el área de click es ~23px:
			   padding + background-clip dibujan solo el punto. */
			.dots__dot {
				appearance: none;
				border: none;
				box-sizing: content-box;
				width: 7px;
				height: 7px;
				padding: 8px;
				background-clip: content-box;
				border-radius: 999px;
				background-color: var(--border-strong);
				cursor: pointer;
				transition:
					transform 0.24s var(--ease),
					background-color 0.24s var(--ease);
			}

			.dots__dot[aria-current] {
				background-color: var(--accent);
				transform: scaleX(2.6);
				border-radius: 999px;
			}

			/* ---------- LIGHTBOX ---------- */
			.lightbox {
				max-width: 90vw;
				max-height: 85vh;
				width: auto;
				height: auto;
				margin: auto;
				padding: 0;
				border: none;
				background: none;
				overflow: visible;
			}

			.lightbox::backdrop {
				background: rgba(6, 7, 9, 0.82);
				backdrop-filter: blur(2px);
			}

			.lightbox__img {
				display: block;
				max-width: 90vw;
				max-height: 85vh;
				width: auto;
				height: auto;
				border-radius: 12px;
				border: 1px solid var(--border-strong);
				box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.9);
			}

			.lightbox__close {
				position: absolute;
				top: -0.6rem;
				right: -0.6rem;
				width: 2.2rem;
				height: 2.2rem;
				display: grid;
				place-items: center;
				border-radius: 999px;
				border: 1px solid var(--border-strong);
				background: var(--surface);
				color: var(--text);
				font-size: 1rem;
				line-height: 1;
				cursor: pointer;
				transition:
					transform 0.24s var(--ease),
					background-color 0.24s var(--ease);
			}

			.lightbox__close:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}

			/* Entrada: fade + scale (curva y duración del brief) */
			.lightbox[open] {
				animation: lightbox-in 0.24s var(--ease);
			}

			.lightbox[open]::backdrop {
				animation: lightbox-backdrop 0.24s var(--ease);
			}

			@keyframes lightbox-in {
				from {
					opacity: 0;
					transform: scale(0.97);
				}
				to {
					opacity: 1;
					transform: scale(1);
				}
			}

			@keyframes lightbox-backdrop {
				from {
					opacity: 0;
				}
				to {
					opacity: 1;
				}
			}

			/* ---------- SKILLS ---------- */
			.skills__grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5rem;
				padding: 0 1.5rem;
			}

			.skill-group {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 14px;
				padding: 1.2rem 1.3rem 1.4rem;
			}

			.skill-group__label {
				margin: 0 0 0.9rem;
				font-size: 0.68rem;
				text-transform: uppercase;
				letter-spacing: 0.18em;
				color: var(--text-3);
				font-weight: 650;
			}

			.skill-group__items {
				margin: 0;
				font-family: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, Consolas,
					monospace;
				font-size: 0.82rem;
				line-height: 1.9;
				color: var(--text-2);
			}

			/* ---------- FOOTER ---------- */
			.footer {
				border-top: 1px solid var(--border);
				margin-top: 2rem;
				padding: 5rem 1.5rem 4rem;
			}

			.footer__inner {
				max-width: var(--maxw);
				margin: 0 auto;
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.footer__eyebrow {
				margin: 0 0 0.5rem;
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				color: var(--text-3);
				font-weight: 600;
			}

			.footer__title {
				margin: 0 0 1.4rem;
				font-size: clamp(1.8rem, 5vw, 2.8rem);
				letter-spacing: -0.02em;
				font-weight: 640;
			}

			.footer__cta {
				display: inline-block;
				color: var(--text);
				text-decoration: none;
				font-size: clamp(1.05rem, 3vw, 1.4rem);
				font-weight: 550;
				padding: 0.65rem 1.4rem;
				border-radius: 999px;
				border: 1px solid var(--border-strong);
				background: var(--surface);
				transition:
					transform 0.24s var(--ease),
					border-color 0.24s var(--ease),
					background-color 0.24s var(--ease);
			}

			.footer__links {
				display: flex;
				gap: 1.6rem;
				margin-top: 1.8rem;
			}

			.footer__links a {
				color: var(--text-2);
				text-decoration: none;
				font-size: 0.92rem;
				transition: color 0.2s var(--ease);
			}

			.footer__meta {
				margin: 1.8rem 0 0;
				display: flex;
				gap: 0.6rem;
				color: var(--text-3);
				font-size: 0.82rem;
			}

			/* ---------- HOVER (solo dispositivos con puntero fino) ---------- */
			@media (hover: hover) and (pointer: fine) {
				.carousel__arrow {
					display: grid;
				}
				.carousel__arrow:not(:disabled):hover {
					background: var(--surface-2);
				}
				.card__zoom {
					cursor: zoom-in;
				}
				.card__zoom:hover img {
					transform: scale(1.03);
				}
				.lightbox__close:hover {
					background: var(--surface-2);
					transform: scale(1.06);
				}
				.link:hover {
					opacity: 0.82;
				}
				.link:hover span {
					transform: translate(2px, -2px);
				}
				.footer__cta:hover {
					border-color: var(--accent);
					background: var(--surface-2);
				}
				.footer__links a:hover {
					color: var(--text);
				}
				.dots__dot:hover {
					background: var(--text-3);
				}
			}

			/* ---------- PRESSABLES ---------- */
			.link:active,
			.footer__cta:active,
			.dots__dot:active {
				transform: scale(0.97);
			}
			.dots__dot[aria-current]:active {
				transform: scaleX(2.6) scale(0.97);
			}

			/* ---------- ENTRADA HERO (stagger) ---------- */
			.intro {
				opacity: 0;
				transform: translateY(12px);
				animation: intro-in 0.5s var(--ease) forwards;
				animation-delay: calc(var(--i) * 90ms + 80ms);
			}

			@keyframes intro-in {
				to {
					opacity: 1;
					transform: none;
				}
			}

			/* ---------- REVEALS ON-SCROLL ---------- */
			[data-reveal] {
				opacity: 0;
				transform: translateY(10px);
				transition:
					opacity 0.5s var(--ease),
					transform 0.5s var(--ease);
				transition-delay: var(--reveal-delay, 0ms);
			}

			[data-reveal].is-visible {
				opacity: 1;
				transform: none;
			}

			/* ---------- DESKTOP ---------- */
			/* El tamaño de la tarjeta y el peek se manejan de forma continua
			   con --card-w en .carousel__track, sin saltos por breakpoint. */
			@media (min-width: 720px) {
				.skills__grid {
					grid-template-columns: repeat(3, 1fr);
				}
			}

			/* ---------- REDUCED MOTION: solo fades ---------- */
			@media (prefers-reduced-motion: reduce) {
				:global(html) {
					scroll-behavior: auto;
				}
				.carousel__track {
					scroll-snap-type: none;
				}
				.intro {
					transform: none;
					animation: fade-only 0.4s var(--ease) forwards;
					animation-delay: calc(var(--i) * 60ms);
				}
				[data-reveal] {
					transform: none;
					transition: opacity 0.4s var(--ease);
				}
				[data-reveal].is-visible {
					transform: none;
				}
				.link:active,
				.footer__cta:active,
				.dots__dot:active,
				.dots__dot[aria-current]:active,
				.carousel__arrow:not(:disabled):active {
					transform: none;
				}
				.link span {
					transition: none;
				}
				.dots__dot[aria-current] {
					transform: scaleX(2.6);
				}
				/* Lightbox: solo fade, sin scale */
				.lightbox[open] {
					animation: lightbox-backdrop 0.2s var(--ease);
				}
				.card__zoom img {
					transition: none;
				}
			}

			@keyframes fade-only {
				to {
					opacity: 1;
				}
			}
		</style>

		<script>
			// Reveals on-scroll (una sola vez).
			const revealItems = document.querySelectorAll('[data-reveal]');
			if ('IntersectionObserver' in window && revealItems.length) {
				const io = new IntersectionObserver(
					(entries, obs) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								obs.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
				);
				revealItems.forEach((el) => io.observe(el));
			} else {
				revealItems.forEach((el) => el.classList.add('is-visible'));
			}

			// Carrusel: dots reflejan la tarjeta activa + navegación por click.
			// La tarjeta activa es la MÁS CERCANA AL CENTRO del track (robusto
			// frente a snap por centro, primera/última tarjeta y ambos anchos
			// de peek). Se recalcula en scroll con rAF (una vez por frame).
			const track = document.getElementById('carousel-track');
			const dots = Array.from(
				document.querySelectorAll<HTMLButtonElement>('.dots__dot')
			);
			const prevBtn = document.querySelector<HTMLButtonElement>('[data-prev]');
			const nextBtn = document.querySelector<HTMLButtonElement>('[data-next]');

			if (track && dots.length) {
				const cards = Array.from(track.querySelectorAll<HTMLElement>('.card'));
				let activeIndex = -1;

				const setActive = (index: number) => {
					if (index === activeIndex) return;
					activeIndex = index;
					dots.forEach((dot, i) => {
						if (i === index) dot.setAttribute('aria-current', 'true');
						else dot.removeAttribute('aria-current');
					});
					if (prevBtn) prevBtn.disabled = index === 0;
					if (nextBtn) nextBtn.disabled = index === cards.length - 1;
				};

				const nearestToCenter = () => {
					const trackRect = track.getBoundingClientRect();
					const center = trackRect.left + trackRect.width / 2;
					let best = 0;
					let bestDist = Infinity;
					cards.forEach((card, i) => {
						const r = card.getBoundingClientRect();
						const dist = Math.abs(r.left + r.width / 2 - center);
						if (dist < bestDist) {
							bestDist = dist;
							best = i;
						}
					});
					return best;
				};

				const sync = () => setActive(nearestToCenter());

				let ticking = false;
				track.addEventListener(
					'scroll',
					() => {
						if (ticking) return;
						ticking = true;
						requestAnimationFrame(() => {
							sync();
							ticking = false;
						});
					},
					{ passive: true }
				);
				window.addEventListener('resize', sync);
				sync();

				// Navegación: centra la tarjeta pedida (scrollTo manual para no
				// arrastrar el scroll vertical de la página). La usan dots y flechas.
				const prefersReduced = matchMedia(
					'(prefers-reduced-motion: reduce)'
				).matches;

				const centerCard = (index: number) => {
					const card = cards[index];
					if (!card) return;
					const trackRect = track.getBoundingClientRect();
					const cardRect = card.getBoundingClientRect();
					const target =
						track.scrollLeft +
						(cardRect.left - trackRect.left) -
						(track.clientWidth - cardRect.width) / 2;
					track.scrollTo({
						left: target,
						behavior: prefersReduced ? 'auto' : 'smooth',
					});
				};

				dots.forEach((dot, i) => {
					dot.addEventListener('click', () => centerCard(i));
				});
				prevBtn?.addEventListener('click', () => centerCard(activeIndex - 1));
				nextBtn?.addEventListener('click', () => centerCard(activeIndex + 1));
			}

			// Lightbox: click/tap en una captura abre el <dialog> reutilizable.
			// Un swipe del carrusel NO dispara click en la imagen, así que el
			// click nativo separa gesto de zoom sin lógica extra.
			const lightbox = document.getElementById(
				'lightbox'
			) as HTMLDialogElement | null;
			const lightboxImg = document.getElementById(
				'lightbox-img'
			) as HTMLImageElement | null;

			if (lightbox && lightboxImg && typeof lightbox.showModal === 'function') {
				const zoomButtons = Array.from(
					document.querySelectorAll<HTMLButtonElement>('.card__zoom')
				);

				zoomButtons.forEach((btn) => {
					btn.addEventListener('click', () => {
						const src = btn.dataset.zoomSrc;
						if (!src) return;
						lightboxImg.src = src;
						lightboxImg.alt = btn.dataset.zoomAlt || '';
						lightbox.showModal();
					});
				});

				// Cierra al hacer click en el backdrop o en el botón ✕.
				lightbox.addEventListener('click', (event) => {
					const target = event.target as HTMLElement;
					if (target === lightbox || target.closest('[data-lightbox-close]')) {
						lightbox.close();
					}
				});

				// Libera la imagen al cerrar (Escape incluido, nativo del dialog).
				lightbox.addEventListener('close', () => {
					lightboxImg.removeAttribute('src');
				});
			}
		</script>
	</body>
</html>
