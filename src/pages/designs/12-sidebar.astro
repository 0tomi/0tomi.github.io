---
// ============================================================
// Diseño 12 — "Sidebar"
// Identidad persistente: columna izquierda fija (foto, nombre,
// contacto) mientras los proyectos scrollean a la derecha.
// Sobrio, oscuro, acento periwinkle. En mobile colapsa a columna.
// Fuente única de contenido: src/data/profile.ts
// ============================================================
import { profile, projects, skills } from '../../data/profile';

const metaDescription = `${profile.name} — ${profile.role}. ${profile.tagline}`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={metaDescription} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{profile.name} — {profile.role}</title>
	</head>
	<body>
		<div class="layout">
			<!-- IDENTIDAD (sticky en desktop) -->
			<aside class="side">
				<div class="side__inner">
					<img
						class="side__avatar intro"
						style="--i: 0"
						src={profile.avatar}
						alt={`Foto de ${profile.name}`}
						width="160"
						height="160"
						decoding="async"
					/>
					<h1 class="side__name intro" style="--i: 1">{profile.name}</h1>
					<p class="side__role intro" style="--i: 2">{profile.role}</p>
					<p class="side__tagline intro" style="--i: 3">{profile.tagline}</p>

					<nav class="side__nav intro" style="--i: 4" aria-label="Secciones">
						<a href="#proyectos">Proyectos</a>
						<a href="#stack">Stack</a>
						<a href="#contacto">Contacto</a>
					</nav>

					<p class="side__links intro" style="--i: 5">
						{
							profile.links.github && (
								<a href={profile.links.github} target="_blank" rel="noopener noreferrer">
									GitHub
								</a>
							)
						}
						{
							profile.links.linkedin && (
								<a href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">
									LinkedIn
								</a>
							)
						}
					</p>
				</div>
			</aside>

			<!-- CONTENIDO -->
			<main class="content">
				<section id="proyectos" aria-labelledby="proyectos-title">
					<h2 id="proyectos-title" class="section-title" data-reveal>Proyectos</h2>
					<div class="works">
						{
							projects.map((project, i) => (
								<article class="work" data-reveal aria-labelledby={`work-name-${i}`}>
									<div class="work__frame">
										{project.image ? (
											<button
												type="button"
												class="work__zoom"
												data-zoom-src={project.image}
												data-zoom-alt={`Captura del proyecto ${project.name}`}
												aria-label={`Ampliar captura de ${project.name}`}
											>
												<img
													src={project.image}
													alt={`Captura del proyecto ${project.name}`}
													width="1600"
													height="1000"
													loading={i === 0 ? 'eager' : 'lazy'}
													decoding="async"
												/>
											</button>
										) : (
											<div class="work__fallback" aria-hidden="true">
												<span>{project.name.charAt(0).toUpperCase()}</span>
											</div>
										)}
									</div>
									<div class="work__head">
										<h3 id={`work-name-${i}`} class="work__name">
											{project.name}
										</h3>
										{project.year && <span class="work__year">{project.year}</span>}
									</div>
									<p class="work__desc">{project.description}</p>
									{project.stack.length > 0 && (
										<p class="work__stack" aria-label="Tecnologías">
											{project.stack.join(' · ')}
										</p>
									)}
									{(project.repo || project.demo) && (
										<p class="work__links">
											{project.demo && (
												<a href={project.demo} target="_blank" rel="noopener noreferrer">
													Ver demo <span aria-hidden="true">↗</span>
												</a>
											)}
											{project.repo && (
												<a href={project.repo} target="_blank" rel="noopener noreferrer">
													Código <span aria-hidden="true">↗</span>
												</a>
											)}
										</p>
									)}
								</article>
							))
						}
					</div>
				</section>

				<section id="stack" aria-labelledby="stack-title">
					<h2 id="stack-title" class="section-title" data-reveal>Stack</h2>
					<div class="skills">
						{
							skills.map((group, i) => (
								<div class="skills__group" data-reveal style={`--reveal-delay: ${i * 50}ms`}>
									<h3>{group.label}</h3>
									<p>{group.items.join(' · ')}</p>
								</div>
							))
						}
					</div>
				</section>

				<section id="contacto" aria-labelledby="contacto-title" class="contact">
					<div data-reveal>
						<h2 id="contacto-title" class="section-title">Contacto</h2>
						<p class="contact__pitch">
							¿Tenés un proyecto en mente? Escribime.
						</p>
						<a class="contact__cta" href={`mailto:${profile.email}`}>{profile.email}</a>
						<p class="contact__meta">{profile.location}</p>
					</div>
				</section>
			</main>
		</div>

		<!-- LIGHTBOX -->
		<dialog class="lightbox" id="lightbox" aria-label="Vista ampliada de la captura">
			<button type="button" class="lightbox__close" data-lightbox-close aria-label="Cerrar">
				<span aria-hidden="true">✕</span>
			</button>
			<img class="lightbox__img" id="lightbox-img" alt="" width="1600" height="1000" decoding="async" />
		</dialog>

		<style>
			:root {
				--bg: #101318;
				--surface: #171b22;
				--border: rgba(255, 255, 255, 0.08);
				--border-strong: rgba(255, 255, 255, 0.15);
				--text: #edeff3;
				--text-2: #a0a7b4;
				--text-3: #697080;
				--accent: #8f9fe8;
				--mono: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, Consolas,
					monospace;
				--ease: cubic-bezier(0.23, 1, 0.32, 1);
			}

			* {
				box-sizing: border-box;
			}

			:global(html) {
				scroll-behavior: smooth;
			}

			:global(body) {
				margin: 0;
				background: var(--bg);
				color: var(--text);
				font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				overflow-x: hidden;
			}

			img {
				display: block;
				max-width: 100%;
				height: auto;
			}

			.layout {
				max-width: 1280px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			/* ---------- SIDEBAR / IDENTIDAD ---------- */
			.side {
				padding: 3.5rem 0 1rem;
			}

			.side__avatar {
				width: clamp(104px, 26vw, 132px);
				aspect-ratio: 1;
				border-radius: 50%;
				object-fit: cover;
				border: 1px solid var(--border-strong);
			}

			.side__name {
				margin: 1.4rem 0 0;
				font-size: clamp(2rem, 6vw, 2.9rem);
				line-height: 1.05;
				letter-spacing: -0.02em;
				font-weight: 650;
			}

			.side__role {
				margin: 0.7rem 0 0;
				font-family: var(--mono);
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				color: var(--accent);
			}

			.side__tagline {
				margin: 1rem 0 0;
				color: var(--text-2);
				max-width: 40ch;
			}

			.side__nav {
				display: none;
				flex-direction: column;
				gap: 0.7rem;
				margin-top: 2.6rem;
			}

			.side__nav a {
				color: var(--text-3);
				text-decoration: none;
				font-family: var(--mono);
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.16em;
				width: fit-content;
				transition: color 0.2s var(--ease), transform 0.2s var(--ease);
			}

			.side__links {
				margin: 2rem 0 0;
				display: flex;
				gap: 1.3rem;
			}

			.side__links a {
				color: var(--text-2);
				text-decoration: none;
				font-size: 0.9rem;
				transition: color 0.2s var(--ease);
			}

			/* ---------- CONTENIDO ---------- */
			.content section {
				padding: 3rem 0 1rem;
			}

			.section-title {
				margin: 0 0 1.8rem;
				font-size: clamp(1.4rem, 3.4vw, 1.9rem);
				letter-spacing: -0.015em;
				font-weight: 640;
			}

			.works {
				display: grid;
				gap: 2.6rem;
			}

			/* En pantallas medianas+ el proyecto es una fila compacta:
			   miniatura al costado, texto al lado. La captura grande
			   queda a un click de distancia (zoom). */
			@media (min-width: 720px) {
				.work {
					display: grid;
					grid-template-columns: 300px minmax(0, 1fr);
					column-gap: 1.7rem;
					align-items: start;
				}
				.work__frame {
					grid-row: 1 / span 4;
				}
				.work__head {
					margin-top: 0;
				}
			}

			.work__frame {
				border: 1px solid var(--border);
				border-radius: 12px;
				overflow: hidden;
				background: var(--surface);
			}

			.work__frame img {
				width: 100%;
				aspect-ratio: 16 / 10;
				object-fit: cover;
			}

			.work__zoom {
				display: block;
				width: 100%;
				margin: 0;
				padding: 0;
				border: none;
				background: none;
				cursor: pointer;
			}

			.work__zoom img {
				transition: transform 0.3s var(--ease);
			}

			.work__zoom:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: -3px;
			}

			.work__fallback {
				aspect-ratio: 16 / 10;
				display: grid;
				place-items: center;
			}

			.work__fallback span {
				font-size: clamp(2.5rem, 8vw, 4rem);
				font-weight: 700;
				color: var(--text-3);
			}

			.work__head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				margin-top: 1.1rem;
			}

			.work__name {
				margin: 0;
				font-size: 1.2rem;
				letter-spacing: -0.01em;
				font-weight: 640;
			}

			.work__year {
				font-family: var(--mono);
				font-size: 0.78rem;
				color: var(--text-3);
				font-variant-numeric: tabular-nums;
			}

			.work__desc {
				margin: 0.55rem 0 0;
				color: var(--text-2);
				font-size: 0.95rem;
				max-width: 62ch;
			}

			.work__stack {
				margin: 0.7rem 0 0;
				font-family: var(--mono);
				font-size: 0.78rem;
				letter-spacing: 0.02em;
				color: var(--text-3);
			}

			.work__links {
				margin: 0.8rem 0 0;
				display: flex;
				gap: 1.4rem;
			}

			.work__links a {
				color: var(--accent);
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 550;
				transition: opacity 0.2s var(--ease);
			}

			/* ---------- SKILLS ---------- */
			.skills {
				display: grid;
				gap: 1.6rem;
			}

			.skills__group h3 {
				margin: 0 0 0.45rem;
				font-family: var(--mono);
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				color: var(--text-3);
				font-weight: 600;
			}

			.skills__group p {
				margin: 0;
				font-family: var(--mono);
				font-size: 0.88rem;
				color: var(--text-2);
			}

			/* ---------- CONTACTO ---------- */
			.contact {
				padding-bottom: 4.5rem;
			}

			.contact__pitch {
				margin: 0 0 1.2rem;
				color: var(--text-2);
			}

			.contact__cta {
				display: inline-block;
				color: var(--text);
				text-decoration: none;
				font-size: clamp(1.05rem, 3vw, 1.3rem);
				font-weight: 550;
				border-bottom: 1px solid var(--border-strong);
				padding-bottom: 2px;
				transition: border-color 0.2s var(--ease);
			}

			.contact__meta {
				margin: 1.6rem 0 0;
				font-family: var(--mono);
				font-size: 0.78rem;
				color: var(--text-3);
			}

			/* ---------- LIGHTBOX ---------- */
			.lightbox {
				max-width: 90vw;
				max-height: 85vh;
				margin: auto;
				padding: 0;
				border: none;
				background: none;
				overflow: visible;
			}

			.lightbox::backdrop {
				background: rgba(7, 9, 12, 0.85);
				backdrop-filter: blur(2px);
			}

			.lightbox__img {
				max-width: 90vw;
				max-height: 85vh;
				width: auto;
				height: auto;
				border-radius: 10px;
				border: 1px solid var(--border-strong);
			}

			.lightbox__close {
				position: absolute;
				top: -0.6rem;
				right: -0.6rem;
				width: 2.2rem;
				height: 2.2rem;
				display: grid;
				place-items: center;
				border-radius: 999px;
				border: 1px solid var(--border-strong);
				background: var(--surface);
				color: var(--text);
				cursor: pointer;
				transition: transform 0.16s var(--ease);
			}

			.lightbox[open] {
				animation: lb-in 0.24s var(--ease);
			}

			.lightbox[open]::backdrop {
				animation: lb-fade 0.24s var(--ease);
			}

			@keyframes lb-in {
				from {
					opacity: 0;
					transform: scale(0.97);
				}
			}

			@keyframes lb-fade {
				from {
					opacity: 0;
				}
			}

			/* ---------- MOTION ---------- */
			.intro {
				opacity: 0;
				transform: translateY(10px);
				animation: intro-in 0.5s var(--ease) forwards;
				animation-delay: calc(var(--i) * 80ms + 60ms);
			}

			@keyframes intro-in {
				to {
					opacity: 1;
					transform: none;
				}
			}

			[data-reveal] {
				opacity: 0;
				transform: translateY(10px);
				transition:
					opacity 0.5s var(--ease),
					transform 0.5s var(--ease);
				transition-delay: var(--reveal-delay, 0ms);
			}

			[data-reveal].is-visible {
				opacity: 1;
				transform: none;
			}

			/* ---------- HOVER / PRESS ---------- */
			@media (hover: hover) and (pointer: fine) {
				.work__zoom {
					cursor: zoom-in;
				}
				.work__zoom:hover img {
					transform: scale(1.02);
				}
				.side__nav a:hover {
					color: var(--text);
					transform: translateX(3px);
				}
				.side__links a:hover,
				.footer__links a:hover {
					color: var(--text);
				}
				.work__links a:hover {
					opacity: 0.8;
				}
				.contact__cta:hover {
					border-color: var(--accent);
				}
				.lightbox__close:hover {
					transform: scale(1.06);
				}
			}

			.contact__cta:active,
			.work__links a:active {
				opacity: 0.7;
			}

			/* ---------- DESKTOP: layout de dos columnas ---------- */
			@media (min-width: 900px) {
				.layout {
					display: grid;
					grid-template-columns: minmax(300px, 38%) 1fr;
					gap: 4.5rem;
				}
				.side__inner {
					position: sticky;
					top: 0;
					max-height: 100svh;
					display: flex;
					flex-direction: column;
					justify-content: center;
					padding: 3rem 0;
				}
				.side {
					padding: 0;
				}
				.side__nav {
					display: flex;
				}
				.content {
					padding: 3.5rem 0;
				}
				.content section:first-child {
					padding-top: 1.5rem;
				}
			}

			/* ---------- REDUCED MOTION ---------- */
			@media (prefers-reduced-motion: reduce) {
				:global(html) {
					scroll-behavior: auto;
				}
				.intro {
					transform: none;
					animation: fade-only 0.4s var(--ease) forwards;
					animation-delay: calc(var(--i) * 50ms);
				}
				[data-reveal] {
					transform: none;
					transition: opacity 0.4s var(--ease);
				}
				.work__zoom img {
					transition: none;
				}
				.side__nav a {
					transition: color 0.2s var(--ease);
				}
				.lightbox[open] {
					animation: lb-fade 0.2s var(--ease);
				}
			}

			@keyframes fade-only {
				to {
					opacity: 1;
				}
			}
		</style>

		<script>
			// Reveals on-scroll (una sola vez)
			const revealItems = document.querySelectorAll('[data-reveal]');
			if ('IntersectionObserver' in window && revealItems.length) {
				const io = new IntersectionObserver(
					(entries, obs) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								obs.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
				);
				revealItems.forEach((el) => io.observe(el));
			} else {
				revealItems.forEach((el) => el.classList.add('is-visible'));
			}

			// Lightbox reutilizable
			const lightbox = document.getElementById('lightbox') as HTMLDialogElement | null;
			const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

			if (lightbox && lightboxImg && typeof lightbox.showModal === 'function') {
				document.querySelectorAll<HTMLButtonElement>('[data-zoom-src]').forEach((btn) => {
					btn.addEventListener('click', () => {
						const src = btn.dataset.zoomSrc;
						if (!src) return;
						lightboxImg.src = src;
						lightboxImg.alt = btn.dataset.zoomAlt || '';
						lightbox.showModal();
					});
				});
				lightbox.addEventListener('click', (event) => {
					const target = event.target as HTMLElement;
					if (target === lightbox || target.closest('[data-lightbox-close]')) {
						lightbox.close();
					}
				});
				lightbox.addEventListener('close', () => lightboxImg.removeAttribute('src'));
			}
		</script>
	</body>
</html>
