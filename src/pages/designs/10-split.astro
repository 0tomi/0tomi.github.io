---
// ============================================================
// Diseño 10 — "Split"
// Hero horizontal (foto a la izquierda, texto apilado a la derecha)
// + carrusel de tarjetas grandes con captura protagonista.
// Sobrio, oscuro, un único acento verde desaturado.
// Fuente única de contenido: src/data/profile.ts (cero texto hardcodeado).
// Página autocontenida: estilos y scripts propios, sin CSS global.
// ============================================================
import { profile, projects, skills } from '../../data/profile';

const hasGithub = profile.links.github.length > 0;
const hasLinkedin = profile.links.linkedin.length > 0;
const metaDescription = `${profile.name} — ${profile.role}. ${profile.tagline}`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={metaDescription} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{profile.name} — {profile.role}</title>
	</head>
	<body>
		<main>
			<!-- HERO horizontal: foto izquierda, texto derecha -->
			<section class="hero" aria-labelledby="hero-name">
				<div class="hero__inner">
					<div class="hero__avatar intro" style="--i: 0">
						<img
							src={profile.avatar}
							alt={`Foto de ${profile.name}`}
							width="400"
							height="400"
							fetchpriority="high"
							decoding="async"
						/>
					</div>
					<div class="hero__text">
						<h1 id="hero-name" class="hero__name intro" style="--i: 1">
							{profile.name}
						</h1>
						<p class="hero__role intro" style="--i: 2">{profile.role}</p>
						<p class="hero__tagline intro" style="--i: 3">
							{profile.tagline}
						</p>
					</div>
				</div>
			</section>

			<!-- PROYECTOS: carrusel de tarjetas grandes -->
			<section class="work" aria-labelledby="work-title">
				<header class="section-head" data-reveal>
					<p class="eyebrow">Trabajo</p>
					<h2 id="work-title" class="section-head__title">Proyectos</h2>
				</header>

				<div class="carousel" data-reveal style="--reveal-delay: 60ms">
					<ul
						class="carousel__track"
						aria-label="Proyectos — desplazá horizontalmente"
					>
						{
							projects.map((project) => (
								<li class="card">
									<figure class="card__media">
										{project.image ? (
											<button
												type="button"
												class="card__zoom"
												data-zoom
												data-src={project.image}
												data-caption={project.name}
												aria-label={`Ampliar captura de ${project.name}`}
											>
												<img
													src={project.image}
													alt={`Captura del proyecto ${project.name}`}
													width="1600"
													height="1000"
													loading="lazy"
													decoding="async"
												/>
											</button>
										) : (
											<div class="card__fallback" aria-hidden="true">
												<span>{project.name.charAt(0).toUpperCase()}</span>
											</div>
										)}
									</figure>
									<div class="card__body">
										<div class="card__heading">
											<h3 class="card__name">{project.name}</h3>
											{project.year && (
												<span class="card__year">{project.year}</span>
											)}
										</div>
										<p class="card__desc">{project.description}</p>
										{project.stack.length > 0 && (
											<p class="card__stack">{project.stack.join(' · ')}</p>
										)}
										{(project.repo || project.demo) && (
											<div class="card__links">
												{project.demo && (
													<a
														class="link"
														href={project.demo}
														target="_blank"
														rel="noopener noreferrer"
													>
														Ver demo <span aria-hidden="true">↗</span>
													</a>
												)}
												{project.repo && (
													<a
														class="link link--muted"
														href={project.repo}
														target="_blank"
														rel="noopener noreferrer"
													>
														Código <span aria-hidden="true">↗</span>
													</a>
												)}
											</div>
										)}
									</div>
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- SKILLS: label + línea mono, sin cajitas -->
			<section class="skills" aria-labelledby="skills-title">
				<header class="section-head" data-reveal>
					<p class="eyebrow">Stack</p>
					<h2 id="skills-title" class="section-head__title">Herramientas</h2>
				</header>
				<dl class="skills__list">
					{
						skills.map((group, i) => (
							<div
								class="skill-row"
								data-reveal
								style={`--reveal-delay: ${i * 50}ms`}
							>
								<dt class="skill-row__label">{group.label}</dt>
								<dd class="skill-row__items">{group.items.join(' · ')}</dd>
							</div>
						))
					}
				</dl>
			</section>

			<!-- FOOTER / CONTACTO -->
			<footer class="footer" aria-labelledby="footer-title">
				<div class="footer__inner" data-reveal>
					<p class="eyebrow">Contacto</p>
					<h2 id="footer-title" class="footer__title">¿Trabajamos juntos?</h2>
					<a class="footer__cta" href={`mailto:${profile.email}`}>
						{profile.email}
					</a>
					<div class="footer__links">
						{
							hasGithub && (
								<a
									href={profile.links.github}
									target="_blank"
									rel="noopener noreferrer"
								>
									GitHub
								</a>
							)
						}
						{
							hasLinkedin && (
								<a
									href={profile.links.linkedin}
									target="_blank"
									rel="noopener noreferrer"
								>
									LinkedIn
								</a>
							)
						}
					</div>
					<p class="footer__meta">
						<span>{profile.location}</span>
						<span aria-hidden="true">·</span>
						<span>{profile.handle}</span>
					</p>
				</div>
			</footer>
		</main>

		<!-- Lightbox reutilizado para ampliar capturas -->
		<dialog class="lightbox" id="lightbox" aria-label="Captura ampliada">
			<button
				type="button"
				class="lightbox__close"
				id="lightbox-close"
				aria-label="Cerrar"
			>
				✕
			</button>
			<img
				class="lightbox__img"
				id="lightbox-img"
				src=""
				alt=""
				width="1600"
				height="1000"
				decoding="async"
			/>
		</dialog>

		<style>
			:root {
				--bg: #0b0e14;
				--surface: #12161f;
				--surface-2: #1a1f2b;
				--border: rgba(255, 255, 255, 0.08);
				--border-strong: rgba(255, 255, 255, 0.15);
				--text: #eef1f5;
				--text-2: #a5adba;
				--text-3: #6d7684;
				/* Acento: verde desaturado, sobrio (no neón) */
				--accent: #83c9a6;
				--accent-ink: #0b0e14;
				--ease: cubic-bezier(0.23, 1, 0.32, 1);
				--maxw: 1120px;
				--gutter: 1.5rem;
				--mono: ui-monospace, 'SFMono-Regular', 'Cascadia Code', 'Roboto Mono',
					Menlo, Consolas, monospace;
			}

			* {
				box-sizing: border-box;
			}

			:global(body) {
				margin: 0;
				background: var(--bg);
				color: var(--text);
				font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				text-rendering: optimizeLegibility;
				overflow-x: hidden;
			}

			img {
				display: block;
				max-width: 100%;
			}

			ul {
				margin: 0;
				padding: 0;
				list-style: none;
			}

			:global(:focus-visible) {
				outline: 2px solid var(--accent);
				outline-offset: 3px;
				border-radius: 4px;
			}

			.eyebrow {
				margin: 0 0 0.5rem;
				font-family: var(--mono);
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.16em;
				color: var(--text-3);
			}

			/* ---------- HERO ---------- */
			.hero {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: clamp(4rem, 12vw, 7rem) var(--gutter) clamp(3rem, 8vw, 5rem);
			}

			.hero__inner {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				gap: 1.75rem;
			}

			.hero__avatar {
				flex: none;
				width: clamp(140px, 40vw, 180px);
				aspect-ratio: 1;
				border-radius: 24px;
				overflow: hidden;
				border: 1px solid var(--border-strong);
				box-shadow: 0 24px 60px -30px rgba(0, 0, 0, 0.9);
			}

			.hero__avatar img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.hero__text {
				display: flex;
				flex-direction: column;
			}

			.hero__name {
				margin: 0;
				font-size: clamp(2.4rem, 8vw, 4.4rem);
				line-height: 1.03;
				letter-spacing: -0.02em;
				font-weight: 650;
			}

			.hero__role {
				margin: 0.9rem 0 0;
				font-family: var(--mono);
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.16em;
				color: var(--accent);
			}

			.hero__tagline {
				margin: 1.1rem 0 0;
				font-size: clamp(1rem, 2.4vw, 1.15rem);
				color: var(--text-2);
				max-width: 48ch;
				text-wrap: balance;
			}

			/* Desktop: foto izquierda, texto derecha */
			@media (min-width: 720px) {
				.hero__inner {
					flex-direction: row;
					align-items: center;
					text-align: left;
					gap: clamp(2rem, 5vw, 3.5rem);
				}
				.hero__tagline {
					margin-left: 0;
					margin-right: 0;
				}
			}

			/* ---------- SECCIONES ---------- */
			.work,
			.skills {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: clamp(2.5rem, 7vw, 4rem) 0;
			}

			.section-head {
				padding: 0 var(--gutter);
				margin-bottom: 1.75rem;
			}

			.section-head__title {
				margin: 0;
				font-size: clamp(1.7rem, 4vw, 2.4rem);
				letter-spacing: -0.02em;
				font-weight: 640;
			}

			/* ---------- CARRUSEL ---------- */
			.carousel {
				position: relative;
			}

			.carousel__track {
				display: flex;
				gap: 1.25rem;
				overflow-x: auto;
				scroll-snap-type: x mandatory;
				scroll-padding-inline: var(--gutter);
				padding: 0.5rem var(--gutter) 1.5rem;
				scrollbar-width: none;
				-webkit-overflow-scrolling: touch;
				overscroll-behavior-x: contain;
			}

			.carousel__track::-webkit-scrollbar {
				display: none;
			}

			.card {
				flex: 0 0 90vw;
				max-width: 90vw;
				scroll-snap-align: center;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 18px;
				overflow: hidden;
				display: flex;
				flex-direction: column;
			}

			.card__media {
				margin: 0;
				aspect-ratio: 16 / 10;
				background: var(--surface-2);
				overflow: hidden;
			}

			.card__zoom {
				display: block;
				width: 100%;
				height: 100%;
				padding: 0;
				margin: 0;
				border: none;
				background: none;
				cursor: pointer;
			}

			.card__media img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.3s var(--ease);
			}

			.card__fallback {
				width: 100%;
				height: 100%;
				display: grid;
				place-items: center;
				background: var(--surface-2);
			}

			.card__fallback span {
				font-size: clamp(3rem, 12vw, 5rem);
				font-weight: 700;
				color: var(--text-3);
				letter-spacing: -0.03em;
			}

			.card__body {
				padding: 1.4rem 1.4rem 1.6rem;
				display: flex;
				flex-direction: column;
				gap: 0.8rem;
				border-top: 1px solid var(--border);
			}

			.card__heading {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
			}

			.card__name {
				margin: 0;
				font-size: 1.3rem;
				letter-spacing: -0.01em;
				font-weight: 640;
			}

			.card__year {
				font-family: var(--mono);
				font-size: 0.78rem;
				color: var(--text-3);
				font-variant-numeric: tabular-nums;
				flex: none;
			}

			.card__desc {
				margin: 0;
				color: var(--text-2);
				font-size: 0.96rem;
				max-width: 62ch;
			}

			.card__stack {
				margin: 0;
				font-family: var(--mono);
				font-size: 0.8rem;
				color: var(--text-3);
				letter-spacing: 0.01em;
			}

			.card__links {
				display: flex;
				gap: 1.4rem;
				margin-top: 0.2rem;
			}

			.link {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				color: var(--accent);
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 550;
				transition: opacity 0.2s var(--ease);
			}

			.link span {
				transition: transform 0.24s var(--ease);
			}

			.link--muted {
				color: var(--text-2);
			}

			/* ---------- SKILLS ---------- */
			.skills__list {
				margin: 0;
				padding: 0 var(--gutter);
				display: flex;
				flex-direction: column;
			}

			.skill-row {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.3rem;
				padding: 1.1rem 0;
				border-top: 1px solid var(--border);
			}

			.skill-row:last-child {
				border-bottom: 1px solid var(--border);
			}

			.skill-row__label {
				font-family: var(--mono);
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--text-3);
			}

			.skill-row__items {
				margin: 0;
				font-family: var(--mono);
				font-size: 0.92rem;
				color: var(--text-2);
			}

			@media (min-width: 640px) {
				.skill-row {
					grid-template-columns: 180px 1fr;
					gap: 1.5rem;
					align-items: baseline;
				}
			}

			/* ---------- FOOTER ---------- */
			.footer {
				border-top: 1px solid var(--border);
				margin-top: 2rem;
				padding: clamp(3.5rem, 9vw, 5rem) var(--gutter) 4rem;
			}

			.footer__inner {
				max-width: var(--maxw);
				margin: 0 auto;
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.footer__title {
				margin: 0 0 1.4rem;
				font-size: clamp(1.8rem, 5vw, 2.8rem);
				letter-spacing: -0.02em;
				font-weight: 640;
			}

			.footer__cta {
				display: inline-block;
				color: var(--text);
				text-decoration: none;
				font-size: clamp(1.05rem, 3vw, 1.35rem);
				font-weight: 550;
				padding: 0.65rem 1.4rem;
				border-radius: 12px;
				border: 1px solid var(--border-strong);
				background: var(--surface);
				transition:
					transform 0.24s var(--ease),
					border-color 0.24s var(--ease),
					background-color 0.24s var(--ease);
			}

			.footer__links {
				display: flex;
				gap: 1.6rem;
				margin-top: 1.8rem;
			}

			.footer__links a {
				color: var(--text-2);
				text-decoration: none;
				font-size: 0.92rem;
				transition: color 0.2s var(--ease);
			}

			.footer__meta {
				margin: 1.8rem 0 0;
				display: flex;
				gap: 0.6rem;
				font-family: var(--mono);
				color: var(--text-3);
				font-size: 0.82rem;
			}

			/* ---------- LIGHTBOX ---------- */
			.lightbox {
				border: none;
				padding: 0;
				background: none;
				max-width: 100vw;
				max-height: 100vh;
				overflow: visible;
			}

			.lightbox::backdrop {
				background: rgba(4, 6, 10, 0.86);
			}

			.lightbox[open] {
				display: grid;
				place-items: center;
				inset: 0;
				width: 100vw;
				height: 100vh;
			}

			.lightbox__img {
				width: auto;
				height: auto;
				max-width: 90vw;
				max-height: 85vh;
				border-radius: 12px;
				box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.9);
			}

			.lightbox__close {
				position: fixed;
				top: 1rem;
				right: 1rem;
				width: 42px;
				height: 42px;
				display: grid;
				place-items: center;
				border-radius: 999px;
				border: 1px solid var(--border-strong);
				background: var(--surface);
				color: var(--text);
				font-size: 1.05rem;
				line-height: 1;
				cursor: pointer;
				transition:
					transform 0.2s var(--ease),
					background-color 0.2s var(--ease);
			}

			/* Animación de apertura del lightbox */
			.lightbox[open] .lightbox__img {
				animation: zoom-in 0.24s var(--ease);
			}

			@keyframes zoom-in {
				from {
					opacity: 0;
					transform: scale(0.97);
				}
				to {
					opacity: 1;
					transform: scale(1);
				}
			}

			/* ---------- HOVER (solo puntero fino) ---------- */
			@media (hover: hover) and (pointer: fine) {
				.card__zoom {
					cursor: zoom-in;
				}
				.card__zoom:hover img {
					transform: scale(1.03);
				}
				.link:hover {
					opacity: 0.82;
				}
				.link:hover span {
					transform: translate(2px, -2px);
				}
				.footer__cta:hover {
					border-color: var(--accent);
					background: var(--surface-2);
				}
				.footer__links a:hover {
					color: var(--text);
				}
				.lightbox__close:hover {
					background: var(--surface-2);
				}
			}

			/* ---------- PRESSABLES ---------- */
			.link:active,
			.footer__cta:active,
			.lightbox__close:active {
				transform: scale(0.97);
			}

			/* ---------- ENTRADA HERO (stagger) ---------- */
			.intro {
				opacity: 0;
				transform: translateY(12px);
				animation: intro-in 0.5s var(--ease) forwards;
				animation-delay: calc(var(--i) * 90ms + 80ms);
			}

			@keyframes intro-in {
				to {
					opacity: 1;
					transform: none;
				}
			}

			/* ---------- REVEALS ---------- */
			[data-reveal] {
				opacity: 0;
				transform: translateY(10px);
				transition:
					opacity 0.5s var(--ease),
					transform 0.5s var(--ease);
				transition-delay: var(--reveal-delay, 0ms);
			}

			[data-reveal].is-visible {
				opacity: 1;
				transform: none;
			}

			/* ---------- DESKTOP: tarjeta protagonista con peek ---------- */
			@media (min-width: 1024px) {
				.carousel__track {
					scroll-padding-inline: max(
						var(--gutter),
						calc((100vw - var(--maxw)) / 2 + var(--gutter))
					);
					padding-inline: max(
						var(--gutter),
						calc((100vw - var(--maxw)) / 2 + var(--gutter))
					);
				}
				.card {
					flex-basis: min(860px, 76%);
					max-width: min(860px, 76%);
				}
			}

			/* ---------- REDUCED MOTION: solo fades ---------- */
			@media (prefers-reduced-motion: reduce) {
				.carousel__track {
					scroll-snap-type: none;
				}
				.intro {
					transform: none;
					animation: fade-only 0.4s var(--ease) forwards;
					animation-delay: calc(var(--i) * 60ms);
				}
				[data-reveal] {
					transform: none;
					transition: opacity 0.4s var(--ease);
				}
				[data-reveal].is-visible {
					transform: none;
				}
				.card__media img,
				.link span {
					transition: none;
				}
				.card__zoom:hover img {
					transform: none;
				}
				.link:active,
				.footer__cta:active,
				.lightbox__close:active {
					transform: none;
				}
				.lightbox[open] .lightbox__img {
					animation: fade-only 0.2s var(--ease);
				}
			}

			@keyframes fade-only {
				to {
					opacity: 1;
				}
			}
		</style>

		<script>
			// ---------- Reveals on-scroll (una sola vez) ----------
			const revealItems = document.querySelectorAll('[data-reveal]');
			if ('IntersectionObserver' in window && revealItems.length) {
				const io = new IntersectionObserver(
					(entries, obs) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								obs.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
				);
				revealItems.forEach((el) => io.observe(el));
			} else {
				revealItems.forEach((el) => el.classList.add('is-visible'));
			}

			// ---------- Lightbox de capturas ----------
			const dialog = document.getElementById(
				'lightbox'
			) as HTMLDialogElement | null;
			const dialogImg = document.getElementById(
				'lightbox-img'
			) as HTMLImageElement | null;
			const closeBtn = document.getElementById('lightbox-close');
			const zoomBtns = Array.from(
				document.querySelectorAll<HTMLButtonElement>('[data-zoom]')
			);

			if (dialog && dialogImg && zoomBtns.length) {
				const open = (src: string, caption: string) => {
					dialogImg.src = src;
					dialogImg.alt = `Captura ampliada de ${caption}`;
					if (!dialog.open) dialog.showModal();
				};

				zoomBtns.forEach((btn) => {
					// Distinguir click real de arrastre del carrusel:
					// guardamos la posición al presionar y comparamos al soltar.
					let downX = 0;
					let downY = 0;
					btn.addEventListener('pointerdown', (e) => {
						downX = e.clientX;
						downY = e.clientY;
					});
					btn.addEventListener('click', (e) => {
						const dx = Math.abs(e.clientX - downX);
						const dy = Math.abs(e.clientY - downY);
						// Movimiento > 8px = swipe/drag → no abrir.
						// (teclado: clientX/Y = 0 y downX/Y = 0 → dx/dy = 0 → abre)
						if (dx > 8 || dy > 8) return;
						const src = btn.dataset.src;
						const caption = btn.dataset.caption ?? '';
						if (src) open(src, caption);
					});
				});

				closeBtn?.addEventListener('click', () => dialog.close());

				// Cerrar al hacer click en el backdrop (fuera de la imagen).
				dialog.addEventListener('click', (e) => {
					if (e.target === dialog) dialog.close();
				});
				// Escape ya cierra el <dialog> nativo por defecto.
			}
		</script>
	</body>
</html>
